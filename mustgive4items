    title2.TextColor3 = Color3.fromRGB(110, 110, 121)
    title2.TextScaled = true
    title2.Font = Enum.Font.Gotham
    title2.TextXAlignment = Enum.TextXAlignment.Left
    title2.Parent = card2

    -- Toggles (2 columns)
    local toggleData = {
        {label = "Announce", var = "ANNOUNCEMENTS", default = true},
        {label = "Fling", var = "FLING_ENABLED", default = true},
        {label = "Reset Pos", var = "RESET_POS", default = true},
        {label = "Anti-Fling", var = "ANTI_FLING", default = true},
    }
    for i, data in ipairs(toggleData) do
        local row = Instance.new("Frame")
        row.Size = UDim2.new(0.48, -4, 0, 24)
        row.Position = UDim2.new((i-1)%2 * 0.5 + ((i-1)%2 == 0 and 0 or 0.5), 0, 0, 40 + math.floor((i-1)/2) * 28)
        row.BackgroundTransparency = 1
        row.Parent = card2

        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(0.6, 0, 1, 0)
        lbl.BackgroundTransparency = 1
        lbl.Text = data.label
        lbl.TextColor3 = Color3.fromRGB(180, 180, 190)
        lbl.TextScaled = true
        lbl.Font = Enum.Font.Gotham
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.Parent = row

        local toggle = Instance.new("TextButton")
        toggle.Size = UDim2.new(0, 20, 0, 18)
        toggle.Position = UDim2.new(0.65, 0, 0.5, -9)
        toggle.Text = ""
        toggle.BackgroundColor3 = Color3.fromRGB(30,30,40)
        toggle.BackgroundTransparency = 0.2
        toggle.BorderSizePixel = 0
        toggle.Parent = row
        local tCorner2 = Instance.new("UICorner")
        tCorner2.CornerRadius = UDim.new(0, 5)
        tCorner2.Parent = toggle

        local fill = Instance.new("Frame")
        fill.Size = UDim2.new(1, 0, 1, 0)
        fill.BackgroundColor3 = Color3.fromRGB(199,127,192)
        fill.BackgroundTransparency = data.default and 0.1 or 1
        fill.BorderSizePixel = 0
        fill.Parent = toggle
        local fCorner = Instance.new("UICorner")
        fCorner.CornerRadius = UDim.new(0, 5)
        fCorner.Parent = fill

        local isOn = data.default
        toggle.MouseButton1Click:Connect(function()
            isOn = not isOn
            TweenService:Create(fill, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
                BackgroundTransparency = isOn and 0.1 or 1
            }):Play()
            CONFIG[data.var] = isOn
            if data.var == "ANNOUNCEMENTS" and isActive then
                if isOn then startAnnounceLoop() else
                    if announcementConnection then announcementConnection:Disconnect(); announcementConnection = nil end
                end
            end
        end)
    end

    -- Card 3: Fling Force
    local card3 = Instance.new("Frame")
    card3.Size = UDim2.new(0, 240, 0, 190)
    card3.Position = UDim2.new(0, pad + 496, 0, cardY)
    card3.BackgroundColor3 = Color3.fromRGB(18, 18, 24)
    card3.BackgroundTransparency = 0.25
    card3.BorderSizePixel = 0
    card3.Parent = content

    local cardCorner3 = Instance.new("UICorner")
    cardCorner3.CornerRadius = UDim.new(0, 14)
    cardCorner3.Parent = card3

    local title3 = Instance.new("TextLabel")
    title3.Size = UDim2.new(1, -16, 0, 28)
    title3.Position = UDim2.new(0, 8, 0, 8)
    title3.BackgroundTransparency = 1
    title3.Text = "Fling Force"
    title3.TextColor3 = Color3.fromRGB(110, 110, 121)
    title3.TextScaled = true
    title3.Font = Enum.Font.Gotham
    title3.TextXAlignment = Enum.TextXAlignment.Left
    title3.Parent = card3

    -- Slider
    local sliderRow = Instance.new("Frame")
    sliderRow.Size = UDim2.new(1, -16, 0, 50)
    sliderRow.Position = UDim2.new(0, 8, 0, 40)
    sliderRow.BackgroundTransparency = 1
    sliderRow.Parent = card3

    local forceLabel = Instance.new("TextLabel")
    forceLabel.Size = UDim2.new(0.35, 0, 0.4, 0)
    forceLabel.Position = UDim2.new(0, 0, 0, 0)
    forceLabel.BackgroundTransparency = 1
    forceLabel.Text = "Force"
    forceLabel.TextColor3 = Color3.fromRGB(180,180,190)
    forceLabel.TextScaled = true
    forceLabel.Font = Enum.Font.Gotham
    forceLabel.TextXAlignment = Enum.TextXAlignment.Left
    forceLabel.Parent = sliderRow

    local forceValue = Instance.new("TextLabel")
    forceValue.Size = UDim2.new(0.4, 0, 0.4, 0)
    forceValue.Position = UDim2.new(0.5, 0, 0, 0)
    forceValue.BackgroundTransparency = 1
    forceValue.Text = "5.0e7"
    forceValue.TextColor3 = Color3.fromRGB(180,180,190)
    forceValue.TextScaled = true
    forceValue.Font = Enum.Font.Gotham
    forceValue.TextXAlignment = Enum.TextXAlignment.Right
    forceValue.Name = "ForceValue"
    forceValue.Parent = sliderRow

    local sliderTrack = Instance.new("Frame")
    sliderTrack.Size = UDim2.new(1, 0, 0.4, 0)
    sliderTrack.Position = UDim2.new(0, 0, 0.6, 0)
    sliderTrack.BackgroundColor3 = Color3.fromRGB(28,28,37)
    sliderTrack.BackgroundTransparency = 0.3
    sliderTrack.BorderSizePixel = 0
    sliderTrack.Parent = sliderRow
    local stCorner = Instance.new("UICorner")
    stCorner.CornerRadius = UDim.new(0, 999)
    stCorner.Parent = sliderTrack

    local sliderFill = Instance.new("Frame")
    sliderFill.Size = UDim2.new(0.5, 0, 1, 0)
    sliderFill.BackgroundColor3 = Color3.fromRGB(181,111,175)
    sliderFill.BackgroundTransparency = 0.2
    sliderFill.BorderSizePixel = 0
    sliderFill.Parent = sliderTrack
    local sfCorner = Instance.new("UICorner")
    sfCorner.CornerRadius = UDim.new(0, 999)
    sfCorner.Parent = sliderFill

    local handle = Instance.new("Frame")
    handle.Size = UDim2.new(0, 12, 0, 12)
    handle.Position = UDim2.new(0.5, -6, 0.5, -6)
    handle.BackgroundColor3 = Color3.fromRGB(200,160,255)
    handle.BackgroundTransparency = 0.3
    handle.BorderSizePixel = 0
    handle.Parent = sliderTrack
    local hCorner = Instance.new("UICorner")
    hCorner.CornerRadius = UDim.new(1, 0)
    hCorner.Parent = handle

    local dragging = false
    local function updateSlider(x)
        local absPos = sliderTrack.AbsolutePosition
        local size = sliderTrack.AbsoluteSize
        local relX = math.clamp((x - absPos.X) / size.X, 0, 1)
        sliderFill.Size = UDim2.new(relX, 0, 1, 0)
        handle.Position = UDim2.new(relX, -6, 0.5, -6)
        local force = relX * 90000000
        if force < 1000000 then force = 1000000 end
        CONFIG.FLING_FORCE = force
        forceValue.Text = string.format("%.1e", force)
    end

    sliderTrack.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            updateSlider(input.Position.X)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            updateSlider(input.Position.X)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    -- ===== START/STOP LOGIC =====
    toggleBtn.MouseButton1Click:Connect(function()
        if isActive then
            stopSystem()
            toggleBtn.Text = "START"
            toggleBtn.BackgroundColor3 = Color3.fromRGB(199,127,192)
            dot.BackgroundColor3 = Color3.fromRGB(255,80,80)
            statLabel.Text = "OFFLINE"
            statLabel.TextColor3 = Color3.fromRGB(180,180,190)
        else
            startSystem()
            toggleBtn.Text = "STOP"
            toggleBtn.BackgroundColor3 = Color3.fromRGB(200,60,60)
            dot.BackgroundColor3 = Color3.fromRGB(100,255,100)
            statLabel.Text = "ONLINE"
            statLabel.TextColor3 = Color3.fromRGB(100,255,100)
        end
        updateBlacklistCounter()
    end)

    -- Auto‑start if was active
    if getgenv().MM2_ACTIVE then
        isActive = true
        firstWarningSent = false
        savePosition()
        startAnnounceLoop()
        startFlingLoop()
        toggleBtn.Text = "STOP"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(200,60,60)
        dot.BackgroundColor3 = Color3.fromRGB(100,255,100)
        statLabel.Text = "ONLINE"
        statLabel.TextColor3 = Color3.fromRGB(100,255,100)
        updateBlacklistCounter()
    end

    updateBlacklistCounter()
    return gui
end

