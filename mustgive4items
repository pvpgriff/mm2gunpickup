-- ===== TeleportData Blacklist =====
-- Get visited servers from teleport data (survives reinjection)
local function getVisitedServers()
    local data = TeleportService:GetLocalPlayerTeleportData()
    if data and data.visitedServers then
        return data.visitedServers
    end
    return {}
end

-- Save visited servers to teleport data (persists across server hops)
local function saveVisitedServers(visited)
    local data = TeleportService:GetLocalPlayerTeleportData() or {}
    data.visitedServers = visited
    -- We can't directly save, but we'll pass it via TeleportOptions on hop
    return data
end

-- Add current server to visited list
local function addVisitedServer()
    local visited = getVisitedServers()
    local jobId = game.JobId
    if jobId and jobId ~= "" then
        local found = false
        for _, id in ipairs(visited) do
            if id == jobId then found = true; break end
        end
        if not found then
            table.insert(visited, jobId)
        end
    end
    return visited
end

-- Check if current server has been visited
local function isVisited()
    local visited = getVisitedServers()
    local jobId = game.JobId
    if not jobId or jobId == "" then return false end
    for _, id in ipairs(visited) do
        if id == jobId then return true end
    end
    return false
end

-- Clear visited list
local function clearVisited()
    -- We'll just reset by hopping without passing data
    local options = Instance.new("TeleportOptions")
    options:SetTeleportData({ visitedServers = {} })
    pcall(function()
        TeleportService:Teleport(game.PlaceId, player, options)
    end)
end

-- Smart server hop using TeleportData
local hopAttempts = 0
local function serverHop()
    -- Add current server to visited list
    local visited = addVisitedServer()
    hopAttempts = 0

    -- Pass visited list via teleport data
    local options = Instance.new("TeleportOptions")
    options:SetTeleportData({
        visitedServers = visited
    })

    pcall(function()
        TeleportService:Teleport(game.PlaceId, player, options)
    end)
end

-- Check visited on load (prevents rejoining same server)
local function checkVisitedOnLoad()
    if isVisited() then
        hopAttempts = hopAttempts + 1
        if hopAttempts <= 5 then
            print("[BLACKLIST] Visited server. Hopping again (attempt " .. hopAttempts .. ")")
            task.wait(1)
            -- Pass updated visited list
            local visited = getVisitedServers()
            local options = Instance.new("TeleportOptions")
            options:SetTeleportData({
                visitedServers = visited
            })
            pcall(function()
                TeleportService:Teleport(game.PlaceId, player, options)
            end)
        else
            print("[BLACKLIST] Max attempts. Clearing blacklist.")
            clearVisited()
            hopAttempts = 0
        end
        return true
    end
    hopAttempts = 0
    return false
end

-- Friend detection (optional)
local function hasFriendsInServer()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p:IsFriendsWith(player.UserId) then
