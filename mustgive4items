    for _ in pairs(getgenv().SERVER_BLACKLIST) do count = count + 1 end
    if gui and gui:FindFirstChild("BlacklistLabel") then
        gui.BlacklistLabel.Text = "🚫 Blacklisted: " .. count
    end
end

