-- ===== PERSISTENCE WATCHDOG =====
-- This runs in the background and reloads the script if the place ID changes.
spawn(function()
    local currentPlaceId = game.PlaceId
    while true do
        task.wait(5)
        if game.PlaceId ~= currentPlaceId then
            print("[PERSIST] Teleport detected – reloading script from URL.")
            currentPlaceId = game.PlaceId
            if getgenv().SCRIPT_URL then
                pcall(function()
                    loadstring(game:HttpGet(getgenv().SCRIPT_URL))()
                end)
            else
                warn("[PERSIST] SCRIPT_URL not set – cannot auto‑reload.")
            end
        end
    end
end)

