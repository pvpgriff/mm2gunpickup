-- POSITION
local function savePosition()
    local root = character and character:FindFirstChild("HumanoidRootPart")
    if root then getgenv().OriginalPos = root.CFrame end
end
local function restorePosition()
    if not CONFIG.RESET_POS or not getgenv().OriginalPos then return end
