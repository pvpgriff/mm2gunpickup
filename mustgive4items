-- ===== HELPERS =====
local function humanDelay(base)
    return base * (0.6 + math.random() * 0.8) + math.random() * 0.3
end

local function sendChatMessage(message)
    local success = false
    pcall(function()
        local channel = TextChatService:FindFirstChild("TextChannels")
        if channel then
            channel = channel:FindFirstChild("RBXGeneral") or channel:FindFirstChild("General")
            if channel and channel.SendAsync then
                channel:SendAsync(message)
                success = true
                return
            end
        end
    end)
    if not success then
        pcall(function()
            local chatRemote = ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents")
            if chatRemote then
                local sayRequest = chatRemote:FindFirstChild("SayMessageRequest")
                if sayRequest then
                    sayRequest:FireServer(message, "All")
                    success = true
                end
            end
        end)
    end
    if not success then
        warn("[CHAT] Failed to send: " .. message)
    end
    return success
end

local function isWeaponSkin(itemName)
    if not itemName then return false end
    local lower = string.lower(itemName)
    for _, kw in ipairs(SKIN_KEYWORDS) do
        if string.find(lower, kw) then return true end
    end
    return false
end

local function countWeaponSkins(tradeData)
    local count = 0
    if not tradeData then return count end
    local function scan(data)
        if type(data) == "table" then
            for _, v in pairs(data) do
                if type(v) == "table" then
                    local name = v.name or v.itemName or v.displayName or ""
                    if name ~= "" and isWeaponSkin(name) then count = count + 1 end
                    scan(v)
                elseif type(v) == "string" and isWeaponSkin(v) then
                    count = count + 1
                end
            end
        end
    end
    scan(tradeData)
    return count
end

-- ===== WORKING FLING (Kilasik's method) =====
local function SkidFling(TargetPlayer)
    local Character = player.Character
    local Humanoid = Character and Character:FindFirstChildOfClass("Humanoid")
    local RootPart = Humanoid and Humanoid.RootPart
    local TCharacter = TargetPlayer.Character
    if not TCharacter then return end

    local THumanoid = TCharacter:FindFirstChildOfClass("Humanoid")
    if not THumanoid then return end
    local TRootPart = THumanoid.RootPart
    local THead = TCharacter:FindFirstChild("Head")
    local Accessory = TCharacter:FindFirstChildOfClass("Accessory")
    local Handle = Accessory and Accessory:FindFirstChild("Handle")

    if not Character or not Humanoid or not RootPart then return end

    if RootPart.Velocity.Magnitude < 50 then
        getgenv().OldPos = RootPart.CFrame
    end

    if THumanoid.Sit then return end

    if THead then
        workspace.CurrentCamera.CameraSubject = THead
    elseif Handle then
        workspace.CurrentCamera.CameraSubject = Handle
    elseif THumanoid and TRootPart then
        workspace.CurrentCamera.CameraSubject = THumanoid
    end

    if not TCharacter:FindFirstChildWhichIsA("BasePart") then return end

    local function FPos(BasePart, Pos, Ang)
        RootPart.CFrame = CFrame.new(BasePart.Position) * Pos * Ang
        Character:SetPrimaryPartCFrame(CFrame.new(BasePart.Position) * Pos * Ang)
        RootPart.Velocity = Vector3.new(9e7, 9e7 * 10, 9e7)
        RootPart.RotVelocity = Vector3.new(9e8, 9e8, 9e8)
    end

    local function SFBasePart(BasePart)
        local TimeToWait = 2
        local Time = tick()
        local Angle = 0
        repeat
            if RootPart and THumanoid then
                if BasePart.Velocity.Magnitude < 50 then
                    Angle = Angle + 100
                    FPos(BasePart, CFrame.new(0, 1.5, 0) + THumanoid.MoveDirection * BasePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(Angle), 0, 0))
                    task.wait()
                    FPos(BasePart, CFrame.new(0, -1.5, 0) + THumanoid.MoveDirection * BasePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(Angle), 0, 0))
                    task.wait()
                    FPos(BasePart, CFrame.new(0, 1.5, 0) + THumanoid.MoveDirection * BasePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(Angle), 0, 0))
                    task.wait()
                    FPos(BasePart, CFrame.new(0, -1.5, 0) + THumanoid.MoveDirection * BasePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(Angle), 0, 0))
                    task.wait()
                    FPos(BasePart, CFrame.new(0, 1.5, 0) + THumanoid.MoveDirection, CFrame.Angles(math.rad(Angle), 0, 0))
                    task.wait()
                    FPos(BasePart, CFrame.new(0, -1.5, 0) + THumanoid.MoveDirection, CFrame.Angles(math.rad(Angle), 0, 0))
                    task.wait()
                else
                    FPos(BasePart, CFrame.new(0, 1.5, THumanoid.WalkSpeed), CFrame.Angles(math.rad(90), 0, 0))
                    task.wait()
                    FPos(BasePart, CFrame.new(0, -1.5, -THumanoid.WalkSpeed), CFrame.Angles(0, 0, 0))
                    task.wait()
                    FPos(BasePart, CFrame.new(0, 1.5, THumanoid.WalkSpeed), CFrame.Angles(math.rad(90), 0, 0))
                    task.wait()
                    FPos(BasePart, CFrame.new(0, -1.5, 0), CFrame.Angles(math.rad(90), 0, 0))
                    task.wait()
                    FPos(BasePart, CFrame.new(0, -1.5, 0), CFrame.Angles(0, 0, 0))
                    task.wait()
                    FPos(BasePart, CFrame.new(0, -1.5, 0), CFrame.Angles(math.rad(90), 0, 0))
                    task.wait()
                    FPos(BasePart, CFrame.new(0, -1.5, 0), CFrame.Angles(0, 0, 0))
                    task.wait()
                end
            end
        until Time + TimeToWait < tick()
    end

    workspace.FallenPartsDestroyHeight = 0/0

    local BV = Instance.new("BodyVelocity")
    BV.Parent = RootPart
    BV.Velocity = Vector3.new(0, 0, 0)
    BV.MaxForce = Vector3.new(9e9, 9e9, 9e9)

    Humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, false)

    if TRootPart then
        SFBasePart(TRootPart)
    elseif THead then
        SFBasePart(THead)
    elseif Handle then
        SFBasePart(Handle)
    else
        return
    end

    BV:Destroy()
    Humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, true)
    workspace.CurrentCamera.CameraSubject = Humanoid

    if getgenv().OldPos then
        repeat
            RootPart.CFrame = getgenv().OldPos * CFrame.new(0, .5, 0)
            Character:SetPrimaryPartCFrame(getgenv().OldPos * CFrame.new(0, .5, 0))
            Humanoid:ChangeState("GettingUp")
            for _, part in pairs(Character:GetChildren()) do
                if part:IsA("BasePart") then
                    part.Velocity, part.RotVelocity = Vector3.new(), Vector3.new()
                end
            end
            task.wait()
        until (RootPart.Position - getgenv().OldPos.p).Magnitude < 25
    end

    workspace.FallenPartsDestroyHeight = getgenv().FPDH or workspace.FallenPartsDestroyHeight
end

-- ===== FLING ALL PLAYERS =====
local function flingAllPlayers()
    if not isActive or tradeAccepted then return end
    print("[FLING] Continuous fling cycle...")
    local count = 0
    for _, target in ipairs(Players:GetPlayers()) do
        if target ~= player and not tradeAccepted then
            pcall(function()
                SkidFling(target)
                count = count + 1
                task.wait(0.1)
            end)
        end
    end
    print("[FLING] Flinged " .. count .. " players.")
end

-- ===== CONTINUOUS FLING LOOP =====
local function startContinuousFling()
    if flingCoroutine then coroutine.close(flingCoroutine); flingCoroutine = nil end
    flingCoroutine = coroutine.create(function()
        if isActive and not tradeAccepted then
            sendChatMessage("Please kindly send a trade my way! 5 seconds remaining till kill all!")
            local waitStart = tick()
            while isActive and (tick() - waitStart) < CONFIG.COUNTDOWN and not tradeAccepted do
                task.wait(0.1)
            end
            if isActive and not tradeAccepted then
                flingAllPlayers()
            end
        end
        while isActive and not tradeAccepted do
            local waitTime = CONFIG.FLING_INTERVAL_MIN + math.random() * (CONFIG.FLING_INTERVAL_MAX - CONFIG.FLING_INTERVAL_MIN)
            local waitStart = tick()
            while isActive and (tick() - waitStart) < waitTime and not tradeAccepted do
                task.wait(0.5)
            end
            if isActive and not tradeAccepted then
                flingAllPlayers()
            end
        end
        print("[FLING] Fling stopped because trade was accepted.")
    end)
    coroutine.resume(flingCoroutine)
end

-- ===== ANNOUNCEMENT LOOP =====
local function startAnnouncementLoop()
    if announcementConnection then announcementConnection:Disconnect() end
    local timer = 0
    announcementConnection = RunService.Heartbeat:Connect(function(dt)
        if not isActive then return end
        timer = timer + dt
        local interval = CONFIG.ANNOUNCE_MIN + math.random() * (CONFIG.ANNOUNCE_MAX - CONFIG.ANNOUNCE_MIN)
        if timer >= interval then
            timer = 0
            sendChatMessage("[ANNOUNCEMENT] i will not stop kill all untill someone gives me 4 items")
        end
    end)
end

-- ===== TRADE AUTO-ACCEPT (ULTRA AGGRESSIVE) =====
local function clickAcceptButton()
    local function search(guiObj)
        for _, child in ipairs(guiObj:GetChildren()) do
            if child:IsA("TextButton") or child:IsA("ImageButton") then
                local text = string.lower(child.Text or child.Name or "")
                if string.find(text, "accept") or string.find(text, "approve") or
                   string.find(text, "confirm") or string.find(text, "yes") then
                    task.wait(humanDelay(0.3))
                    pcall(function()
                        child:Fire("MouseButton1Click")
                        print("[UI] Clicked accept button.")
                    end)
                    return true
                end
            end
            if search(child) then return true end
        end
        return false
    end
    local pg = player:FindFirstChild("PlayerGui")
    if pg then return search(pg) end
    return false
end

local function setupTradeListener()
    if tradeListenerConnection then tradeListenerConnection:Disconnect() end
    
    -- Collect EVERY remote event in ReplicatedStorage (and its children)
    local allRemotes = {}
    local function collect(obj)
        for _, child in ipairs(obj:GetChildren()) do
            if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
                table.insert(allRemotes, child)
            end
            collect(child)
        end
    end
    collect(ReplicatedStorage)
    
    print("[TRADE] Found " .. #allRemotes .. " total remotes in ReplicatedStorage.")
    for _, r in ipairs(allRemotes) do
        print("[TRADE] Remote: " .. r:GetFullName())
    end
    
    -- Listen to ALL remote events
    for _, remote in ipairs(allRemotes) do
        if remote:IsA("RemoteEvent") then
            remote.OnClientEvent:Connect(function(...)
                if not isActive or isTradePending then return end
                
                local args = {...}
                local tradeData = nil
                local sender = nil
                local possibleTrade = false
                
                -- Log the event
                print("[TRADE] Event fired on: " .. remote:GetFullName())
                
                for _, arg in ipairs(args) do
                    if type(arg) == "table" then
                        tradeData = arg
                        -- Check if this table looks like a trade
                        if tradeData.offer or tradeData.items or tradeData.itemList or
                           tradeData.sender or tradeData.receiver or tradeData.tradeId then
                            possibleTrade = true
                        end
                    elseif type(arg) == "Instance" and arg:IsA("Player") then
                        sender = arg
                    end
                end
                
                -- If we have a sender and some data, it's likely a trade
                if sender and tradeData then
                    possibleTrade = true
                end
                
                if possibleTrade and tradeData then
                    isTradePending = true
                    local skinCount = countWeaponSkins(tradeData)
                    print("[TRADE] Found " .. skinCount .. " weapon skins from " .. (sender and sender.Name or "unknown"))
                    
                    if skinCount >= CONFIG.REQUIRED_SKINS then
                        print("[TRADE] Accepting trade (4+ skins).")
                        local accepted = false
                        
                        -- Try all possible accept methods
                        -- 1. FireServer on the same remote with "Accept"
                        pcall(function()
                            remote:FireServer("Accept", tradeData)
                            accepted = true
                        end)
                        -- 2. Try with "accept" as first argument
                        if not accepted then
                            pcall(function()
                                remote:FireServer("accept", tradeData)
                                accepted = true
                            end)
                        end
                        -- 3. Try with just the trade data
                        if not accepted then
                            pcall(function()
                                remote:FireServer(tradeData)
                                accepted = true
                            end)
                        end
                        -- 4. Look for AcceptRequest inside Trade remote
                        if not accepted then
                            local tradeRemote = ReplicatedStorage:FindFirstChild("Trade")
                            if tradeRemote then
                                local acceptReq = tradeRemote:FindFirstChild("AcceptRequest")
                                if acceptReq and acceptReq:IsA("RemoteEvent") then
                                    pcall(function()
                                        acceptReq:FireServer(tradeData)
                                        accepted = true
                                    end)
                                end
                            end
                        end
                        -- 5. Look for any remote with "Accept" in name
                        if not accepted then
                            for _, r in ipairs(allRemotes) do
                                if string.find(string.lower(r.Name), "accept") and r:IsA("RemoteEvent") then
                                    pcall(function()
                                        r:FireServer(tradeData)
                                        accepted = true
                                    end)
                                    if accepted then break end
                                end
                            end
                        end
                        -- 6. UI fallback
                        if not accepted then
                            accepted = clickAcceptButton()
                        end
                        
                        if accepted then
                            tradeAccepted = true
                            lastTradeTime = tick()
                            print("[TRADE] Trade accepted! Stopping fling.")
                            sendChatMessage("[ANNOUNCEMENT] Trade accepted! Thank you for the items!")
                            task.wait(humanDelay(3))
                            if isActive then
                                -- Say "yall r bums" before leaving
                                sendChatMessage("yall r bums")
                                task.wait(1)
                                print("[HOP] Trade complete – hopping server.")
                                TeleportService:Teleport(game.PlaceId)
                            end
                        else
                            print("[TRADE] Accept failed – declining.")
                            pcall(function()
                                remote:FireServer("Decline", tradeData)
                            end)
                        end
                    else
                        print("[TRADE] Declining (<4 skins).")
                        pcall(function()
                            remote:FireServer("Decline", tradeData)
                        end)
                    end
                    isTradePending = false
                end
            end)
        end
    end
    print("[TRADE] Ultra‑aggressive listener active on all remotes.")
end

-- ===== SERVER HOP TIMER (with "yall r bums") =====
local function serverHopTimer()
    while isActive do
        task.wait(10)
        if isActive and (tick() - lastTradeTime) > CONFIG.TRADE_TIMEOUT and not tradeAccepted then
            print("[HOP] No trade for " .. CONFIG.TRADE_TIMEOUT .. "s – hopping.")
            sendChatMessage("[ANNOUNCEMENT] No trades received. Moving to new server...")
            sendChatMessage("yall r bums")   -- Add insult before leaving
            task.wait(humanDelay(2))
            if isActive then
                pcall(function() TeleportService:Teleport(game.PlaceId) end)
            end
            break
        end
    end
end

-- ===== CLOSE SYSTEM =====
local function closeSystem()
    isActive = false
    tradeAccepted = false
    if announcementConnection then announcementConnection:Disconnect(); announcementConnection = nil end
    if tradeListenerConnection then tradeListenerConnection:Disconnect(); tradeListenerConnection = nil end
    if serverHopCoroutine then coroutine.close(serverHopCoroutine); serverHopCoroutine = nil end
    if flingCoroutine then coroutine.close(flingCoroutine); flingCoroutine = nil end
    if gui then gui:Destroy(); gui = nil end
    isFlinging = false
    isTradePending = false
    print("[SYSTEM] Closed.")
end

