local function flingTarget(target)
    local char = player.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local root = hum and hum.RootPart
    local tchar = target.Character
    if not tchar then return end
    local thum = tchar:FindFirstChildOfClass("Humanoid")
    if not thum then return end
    local troot = thum.RootPart
    local thead = tchar:FindFirstChild("Head")
    local acc = tchar:FindFirstChildOfClass("Accessory")
    local handle = acc and acc:FindFirstChild("Handle")
    if not char or not hum or not root then return end

    if root.Velocity.Magnitude < 50 then getgenv().OldPos = root.CFrame end
    if thum.Sit then return end

    if thead then workspace.CurrentCamera.CameraSubject = thead
    elseif handle then workspace.CurrentCamera.CameraSubject = handle
    elseif thum and troot then workspace.CurrentCamera.CameraSubject = thum
    end

    if not tchar:FindFirstChildWhichIsA("BasePart") then return end

    local function setPos(part, pos, ang)
        root.CFrame = CFrame.new(part.Position) * pos * ang
        char:SetPrimaryPartCFrame(CFrame.new(part.Position) * pos * ang)
        root.Velocity = Vector3.new(9e7, 9e7 * 10, 9e7)
        root.RotVelocity = Vector3.new(9e8, 9e8, 9e8)
    end

    local function runLoop(basePart)
        local t = tick()
        local angle = 0
        local bv = Instance.new("BodyVelocity")
        bv.Parent = root
        bv.Velocity = Vector3.new(0,0,0)
        bv.MaxForce = Vector3.new(9e9,9e9,9e9)
        hum:SetStateEnabled(Enum.HumanoidStateType.Seated, false)

        repeat
            if root and thum then
                if not bv.Parent then
                    bv = Instance.new("BodyVelocity")
                    bv.Parent = root
                    bv.Velocity = Vector3.new(0,0,0)
                    bv.MaxForce = Vector3.new(9e9,9e9,9e9)
                end
                root.Velocity = Vector3.new(9e7, 9e7 * 10, 9e7)
                root.RotVelocity = Vector3.new(9e8, 9e8, 9e8)

                if basePart.Velocity.Magnitude < 50 then
                    angle = angle + 100
                    setPos(basePart, CFrame.new(0,1.5,0) + thum.MoveDirection * basePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(angle),0,0))
                    task.wait()
                    setPos(basePart, CFrame.new(0,-1.5,0) + thum.MoveDirection * basePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(angle),0,0))
                    task.wait()
                    setPos(basePart, CFrame.new(0,1.5,0) + thum.MoveDirection * basePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(angle),0,0))
                    task.wait()
                    setPos(basePart, CFrame.new(0,-1.5,0) + thum.MoveDirection * basePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(angle),0,0))
                    task.wait()
                    setPos(basePart, CFrame.new(0,1.5,0) + thum.MoveDirection, CFrame.Angles(math.rad(angle),0,0))
                    task.wait()
                    setPos(basePart, CFrame.new(0,-1.5,0) + thum.MoveDirection, CFrame.Angles(math.rad(angle),0,0))
                    task.wait()
                else
                    setPos(basePart, CFrame.new(0,1.5,thum.WalkSpeed), CFrame.Angles(math.rad(90),0,0))
                    task.wait()
                    setPos(basePart, CFrame.new(0,-1.5,-thum.WalkSpeed), CFrame.Angles(0,0,0))
                    task.wait()
                    setPos(basePart, CFrame.new(0,1.5,thum.WalkSpeed), CFrame.Angles(math.rad(90),0,0))
                    task.wait()
                    setPos(basePart, CFrame.new(0,-1.5,0), CFrame.Angles(math.rad(90),0,0))
                    task.wait()
                    setPos(basePart, CFrame.new(0,-1.5,0), CFrame.Angles(0,0,0))
                    task.wait()
                    setPos(basePart, CFrame.new(0,-1.5,0), CFrame.Angles(math.rad(90),0,0))
                    task.wait()
                    setPos(basePart, CFrame.new(0,-1.5,0), CFrame.Angles(0,0,0))
                    task.wait()
                end
            end
        until t + 2 < tick()
        bv:Destroy()
        hum:SetStateEnabled(Enum.HumanoidStateType.Seated, true)
        workspace.CurrentCamera.CameraSubject = hum
        if getgenv().OldPos then
            repeat
                root.CFrame = getgenv().OldPos * CFrame.new(0,.5,0)
                char:SetPrimaryPartCFrame(getgenv().OldPos * CFrame.new(0,.5,0))
                hum:ChangeState("GettingUp")
                for _, p in pairs(char:GetChildren()) do
                    if p:IsA("BasePart") then
                        p.Velocity, p.RotVelocity = Vector3.new(), Vector3.new()
                    end
                end
                task.wait()
            until (root.Position - getgenv().OldPos.p).Magnitude < 25
        end
        workspace.FallenPartsDestroyHeight = getgenv().FPDH or workspace.FallenPartsDestroyHeight
    end

    workspace.FallenPartsDestroyHeight = 0/0
    if troot then runLoop(troot)
    elseif thead then runLoop(thead)
    elseif handle then runLoop(handle)
    else return end
end

local function flingAll()
    if not isActive then return end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player then
            pcall(function() flingTarget(p); task.wait(0.1) end)
        end
    end
end

-- Loops
local function startFlingLoop()
    if flingCoroutine then coroutine.close(flingCoroutine) end
    flingCoroutine = coroutine.create(function()
        while isActive do
            if not firstWarningSent then
                sendChat("Please kindly send a trade my way! 5 seconds remaining till kill all!")
                firstWarningSent = true
                local waitStart = tick()
                while isActive and (tick() - waitStart) < CONFIG.COUNTDOWN do task.wait(0.1) end
                if not isActive then break end
                flingAll()
            else
                flingAll()
            end
            local waitTime = CONFIG.FLING_INTERVAL_MIN + math.random() * (CONFIG.FLING_INTERVAL_MAX - CONFIG.FLING_INTERVAL_MIN)
            local start = tick()
            while isActive and (tick() - start) < waitTime do task.wait(0.5) end
        end
    end)
    coroutine.resume(flingCoroutine)
end

local function startAnnounceLoop()
    if announcementConnection then announcementConnection:Disconnect() end
    local timer = 0
    announcementConnection = RunService.Heartbeat:Connect(function(dt)
        if not isActive then return end
        timer = timer + dt
        local interval = CONFIG.ANNOUNCE_MIN + math.random() * (CONFIG.ANNOUNCE_MAX - CONFIG.ANNOUNCE_MIN)
        if timer >= interval then
            timer = 0
            sendChat("[ANNOUNCEMENT] i will not stop kill all untill someone gives me 4 items")
        end
    end)
end

-- Controls
local function startSystem()
    if isActive then return end
    isActive = true
    getgenv().MM2_ACTIVE = true
    firstWarningSent = false
    savePosition()
    sendChat("[ANNOUNCEMENT] i will not stop kill all untill someone gives me 4 items")
    startAnnounceLoop()
    startFlingLoop()
end

local function stopSystem()
    isActive = false
    getgenv().MM2_ACTIVE = false
    if announcementConnection then announcementConnection:Disconnect(); announcementConnection = nil end
    if flingCoroutine then coroutine.close(flingCoroutine); flingCoroutine = nil end
    restorePosition()
end

local function closeSystem()
    stopSystem()
    getgenv().SCRIPT_RUNNING = false
    if gui then gui:Destroy(); gui = nil end
end

local function rejoin()
    addBlacklist()
    pcall(function() TeleportService:Teleport(game.PlaceId) end)
end

