--[[
    脚本名称: MM2 高级交易与“杀戮”循环 v2.0
    功能: 自动化公告、定时“击飞”、智能交易接受
    说明: 本脚本加入了随机延迟以模拟人类操作，降低检测风险。
    警告: 使用第三方脚本违反 Roblox 服务条款，可能导致账号封禁。
]]

-- ============================================
-- 服务与配置
-- ============================================
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TeleportService = game:GetService("TeleportService")
local RunService = game:GetService("RunService")
local Debris = game:GetService("Debris")
local TextChatService = game:GetService("TextChatService")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()

-- 配置参数（可在此调整）
local CONFIG = {
    REQUIRED_SKINS = 4,          -- 自动接受交易所需的皮肤数量
    ANNOUNCE_MIN = 5,            -- 公告最短间隔（秒）
    ANNOUNCE_MAX = 8,            -- 公告最长间隔（秒）
    FLING_WARNING_DELAY = 2,     -- 警告后等待时间（秒）
    FLING_COUNTDOWN = 5,         -- 倒计时时间（秒）
}

-- ============================================
-- 状态管理
-- ============================================
local isActive = false
local isFlinging = false
local isTradePending = false
local gui = nil
local announcementConnection = nil
local tradeListenerConnection = nil

-- MM2 皮肤关键词库
local SKIN_KEYWORDS = {
    "knife", "gun", "skin", "blade", "sword", "godly", "ancient",
    "vintage", "chroma", "collectible", "ice", "fire", "dark", "light"
}

-- ============================================
-- 辅助函数
-- ============================================

-- 人性化随机延迟
local function humanDelay(base)
    return base * (0.6 + math.random() * 0.8) + math.random() * 0.5
end

-- 发送聊天消息（服务器广播）
local function sendChatMessage(message)
    local success = false
    -- 方法1: 新版聊天系统
    pcall(function()
        local channel = TextChatService:FindFirstChild("TextChannels")
        if channel then
            channel = channel:FindFirstChild("RBXGeneral") or channel:FindFirstChild("General")
            if channel and channel.SendAsync then
                channel:SendAsync(message)
                success = true
                return
            end
        end
    end)
    -- 方法2: 旧版聊天系统
    if not success then
        pcall(function()
            local chatRemote = ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents")
            if chatRemote then
                local sayRequest = chatRemote:FindFirstChild("SayMessageRequest")
                if sayRequest then
                    sayRequest:FireServer(message, "All")
                    success = true
                end
            end
        end)
    end
    return success
end

-- 检测是否为武器皮肤
local function isWeaponSkin(itemName)
    if not itemName then return false end
    local lowerName = string.lower(itemName)
    for _, keyword in ipairs(SKIN_KEYWORDS) do
        if string.find(lowerName, keyword) then
            return true
        end
    end
    return false
end

-- 统计交易中的武器皮肤数量
local function countWeaponSkins(tradeData)
    local count = 0
    if not tradeData then return count end
    -- 递归遍历交易数据中的物品
    local function scanItems(data)
        if type(data) == "table" then
            for _, v in pairs(data) do
                if type(v) == "table" then
                    local name = v.name or v.itemName or v.displayName or ""
                    if name ~= "" and isWeaponSkin(name) then
                        count = count + 1
                    end
                    scanItems(v)
                elseif type(v) == "string" and isWeaponSkin(v) then
                    count = count + 1
                end
            end
        end
    end
    scanItems(tradeData)
    return count
end

-- ============================================
-- 核心功能
-- ============================================

-- 1. “击飞”所有玩家 (BodyVelocity方法)
local function flingAllPlayers()
    local force = 4000 + math.random(0, 2000)
    local flingCount = 0
    for _, target in ipairs(Players:GetPlayers()) do
        if target ~= player then
            local targetChar = target.Character
            if targetChar then
                local root = targetChar:FindFirstChild("HumanoidRootPart")
                if root then
                    -- 随机方向
                    local angle1 = math.random() * math.pi * 2
                    local angle2 = math.random() * math.pi * 2
                    local forceX = math.sin(angle1) * force * (0.5 + math.random() * 0.5)
                    local forceY = force * (0.8 + math.random() * 0.4)
                    local forceZ = math.cos(angle2) * force * (0.5 + math.random() * 0.5)
                    -- 创建并应用速度
                    local bv = Instance.new("BodyVelocity")
                    bv.Velocity = Vector3.new(forceX, forceY, forceZ)
                    bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
                    bv.Parent = root
                    Debris:AddItem(bv, 1.5 + math.random() * 1.0) -- 自动清理
                    flingCount = flingCount + 1
                    task.wait(humanDelay(0.1)) -- 对每个玩家施加短暂延迟
                end
            end
        end
    end
    print("[系统] 已击飞 " .. flingCount .. " 名玩家")
end

-- 2. 主循环：公告 + 定时“击飞”
local function startMainLoop()
    if announcementConnection then announcementConnection:Disconnect() end
    
    local announceTimer = 0
    announcementConnection = RunService.Heartbeat:Connect(function(deltaTime)
        if not isActive then return end
        
        -- 公告计时器
        announceTimer = announceTimer + deltaTime
        local interval = CONFIG.ANNOUNCE_MIN + math.random() * (CONFIG.ANNOUNCE_MAX - CONFIG.ANNOUNCE_MIN)
        if announceTimer >= interval then
            announceTimer = 0
            sendChatMessage("[ANNOUNCEMENT] i will not stop kill all untill someone gives me 4 items")
        end
        
        -- “击飞”流程 (包含你要求的2秒和5秒延迟)
        if not isFlinging then
            -- 随机触发间隔 (15-25秒，避免太频繁)
            local flingInterval = 15 + math.random(0, 10)
            if (tick() - lastFlingTime) > flingInterval then
                isFlinging = true
                lastFlingTime = tick()
                
                -- 步骤1: 发送警告
                sendChatMessage("Please kindly send a trade my way! 5 seconds remaining till kill all!")
                
                -- 步骤2: 等待2秒 (你要求的)
                task.wait(CONFIG.FLING_WARNING_DELAY)
                
                -- 步骤3: 等待5秒倒计时 (你要求的)
                task.wait(CONFIG.FLING_COUNTDOWN)
                
                -- 步骤4: 执行“击飞”
                if isActive then
                    flingAllPlayers()
                end
                
                isFlinging = false
            end
        end
    end)
end

-- 3. 交易监听与自动接受
local function setupTradeListener()
    if tradeListenerConnection then tradeListenerConnection:Disconnect() end
    
    -- 查找所有交易相关的远程事件
    local tradeRemotes = {}
    for _, child in ipairs(ReplicatedStorage:GetChildren()) do
        if string.find(string.lower(child.Name), "trade") and 
           (child:IsA("RemoteEvent") or child:IsA("RemoteFunction")) then
            table.insert(tradeRemotes, child)
        end
    end
    
    if #tradeRemotes == 0 then
        print("[系统] 未找到交易远程事件，交易功能不可用")
        return
    end
    
    for _, remote in ipairs(tradeRemotes) do
        if remote:IsA("RemoteEvent") then
            remote.OnClientEvent:Connect(function(...)
                if not isActive or isTradePending then return end
                
                local args = {...}
                local tradeData = nil
                for _, arg in ipairs(args) do
                    if type(arg) == "table" then
                        tradeData = arg
                        break
                    end
                end
                
                if tradeData then
                    isTradePending = true
                    local skinCount = countWeaponSkins(tradeData)
                    print("[交易] 检测到 " .. skinCount .. " 件武器皮肤")
                    
                    if skinCount >= CONFIG.REQUIRED_SKINS then
                        print("[交易] 条件满足，自动接受...")
                        -- 模拟人类反应延迟
                        task.wait(humanDelay(0.5))
                        -- 尝试接受交易 (通过远程事件)
                        pcall(function()
                            remote:FireServer("Accept", tradeData) -- 通用方法
                        end)
                        -- 备用方法
                        pcall(function()
                            local acceptRemote = ReplicatedStorage:FindFirstChild("Trade")
                            if acceptRemote then
                                local acceptReq = acceptRemote:FindFirstChild("AcceptRequest")
                                if acceptReq then
                                    acceptReq:FireServer()
                                end
                            end
                        end)
                    else
                        print("[交易] 皮肤不足，自动拒绝")
                        pcall(function()
                            remote:FireServer("Decline", tradeData)
                        end)
                    end
                    isTradePending = false
                end
            end)
        end
    end
    print("[系统] 交易监听器已启动")
end

