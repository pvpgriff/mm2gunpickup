-- ============================================

-- Get all trade-related remotes in ReplicatedStorage
local function getTradeRemotes()
    local remotes = {}
    local possibleNames = {"Trade", "TradeRequest", "SendRequest", "AcceptRequest", 
                           "DeclineRequest", "TradeResponse", "TradeSystem", "TradeEvent"}
    for _, name in ipairs(possibleNames) do
        local remote = ReplicatedStorage:FindFirstChild(name)
        if remote then table.insert(remotes, remote) end
    end
    for _, child in ipairs(ReplicatedStorage:GetChildren()) do
        if string.find(string.lower(child.Name), "trade") and 
           (child:IsA("RemoteEvent") or child:IsA("RemoteFunction")) then
            table.insert(remotes, child)
        end
    end
    return remotes
end

-- Accept a trade using various methods (with random retry timing)
local function acceptTrade(tradeData)
    local remotes = getTradeRemotes()
    local accepted = false
    local attempts = 0
    local maxAttempts = 3 + math.random(0, 2)  -- Random retry count
    
    while not accepted and attempts < maxAttempts do
        attempts = attempts + 1
        for _, remote in ipairs(remotes) do
            if remote:IsA("RemoteEvent") then
                pcall(function()
                    if tradeData then remote:FireServer(tradeData) else remote:FireServer() end
                    accepted = true
                end)
            elseif remote:IsA("RemoteFunction") then
                pcall(function()
                    if tradeData then remote:InvokeServer(tradeData) else remote:InvokeServer() end
                    accepted = true
                end)
            end
            if accepted then break end
        end
        
        -- Try specific MM2 AcceptRequest
        if not accepted then
            local tradeRemote = ReplicatedStorage:FindFirstChild("Trade")
            if tradeRemote then
                local acceptReq = tradeRemote:FindFirstChild("AcceptRequest")
                if acceptReq and acceptReq:IsA("RemoteEvent") then
                    pcall(function()
                        acceptReq:FireServer()
                        accepted = true
                        print("[TRADE] Accepted via Trade.AcceptRequest at " .. os.date("%H:%M:%S"))  -- PROOF
                    end)
                end
            end
        end
        
        -- If not accepted yet, wait with random delay before retry
        if not accepted and attempts < maxAttempts then
            task.wait(mediumHumanWait())
        end
    end
    
    return accepted
end

-- Decline a trade
local function declineTrade(tradeData)
    local remotes = getTradeRemotes()
    for _, remote in ipairs(remotes) do
        if string.find(string.lower(remote.Name), "decline") or 
           string.find(string.lower(remote.Name), "deny") then
            pcall(function()
                if remote:IsA("RemoteEvent") then remote:FireServer(tradeData) 
                else remote:InvokeServer(tradeData) end
                print("[TRADE] Declined at " .. os.date("%H:%M:%S"))  -- PROOF
                return true
            end)
        end
    end
    return false
end

-- Find and click the accept button in the UI (fallback with random delay)
local function clickAcceptButton()
    local function search(gui)
        for _, child in ipairs(gui:GetChildren()) do
            if child:IsA("TextButton") or child:IsA("ImageButton") then
                local text = string.lower(child.Text or child.Name or "")
                if string.find(text, "accept") or string.find(text, "approve") or 
                   string.find(text, "confirm") or string.find(text, "yes") then
                    -- Random delay before clicking (human reaction time)
                    task.wait(shortHumanWait())
                    pcall(function() 
                        child:Fire("MouseButton1Click")
                        print("[UI CLICK] Clicked accept button at " .. os.date("%H:%M:%S"))  -- PROOF
                    end)
                    return true
                end
            end
            if search(child) then return true end
        end
        return false
    end
    local pg = player:FindFirstChild("PlayerGui")
    if pg then return search(pg) end
    return false
end

-- ============================================
-- SET UP TRADE LISTENER (with human-like response timing)
-- ============================================
local function setupTradeListener()
    if tradeListenerConnection then tradeListenerConnection:Disconnect() end
    
    local remotes = getTradeRemotes()
    for _, remote in ipairs(remotes) do
        if remote:IsA("RemoteEvent") then
            local conn = remote.OnClientEvent:Connect(function(...)
                if not isActive or isTradePending then return end
                
                local args = {...}
                local tradeData = nil
                local sender = nil
                
                for _, arg in ipairs(args) do
                    if type(arg) == "table" then tradeData = arg
                    elseif type(arg) == "Instance" and arg:IsA("Player") then sender = arg
                    end
                end
                
                if not tradeData and sender then tradeData = {} end
                
                -- Validate that it's a trade
                local isValid = false
                if tradeData and type(tradeData) == "table" then
                    for _, v in pairs(tradeData) do
                        if type(v) == "table" and (v.name or v.itemName) then isValid = true break
                        elseif type(v) == "string" then isValid = true break
                        end
                    end
                end
                if sender and not tradeData then isValid = true end
                
                if isValid and not isTradePending then
                    isTradePending = true
                    
                    -- Random human-like delay before responding (0.5-2 seconds)
                    local responseDelay = randomHumanWait(0.5, 2.0)
                    print("[TRADE] Received trade from " .. (sender and sender.Name or "unknown") .. 
                          " - responding in " .. string.format("%.2f", responseDelay) .. "s")  -- PROOF
                    task.wait(responseDelay)
                    
                    local skinCount = countWeaponSkins(tradeData)
                    print("[TRADE] Found " .. skinCount .. " weapon skins at " .. os.date("%H:%M:%S"))  -- PROOF
                    
                    -- Log trade for proof
                    table.insert(tradeLog, {
                        time = os.date("%H:%M:%S"),
                        sender = sender and sender.Name or "unknown",
                        skinCount = skinCount,
                        accepted = false
                    })
                    
                    if skinCount >= CONFIG.REQUIRED_SKINS then
                        print("[TRADE] " .. skinCount .. "/" .. CONFIG.REQUIRED_SKINS .. " skins - ACCEPTING")  -- PROOF
                        sendChatMessage("[ANNOUNCEMENT] Trade accepted! Thank you for the items!")
                        
                        -- MM2 requires waiting 6 seconds after items are added
                        -- Add slight random variation to the cooldown wait
                        local cooldownWait = CONFIG.TRADE_COOLDOWN + (math.random() * 0.5 - 0.25)
                        print("[TRADE] Waiting " .. string.format("%.2f", cooldownWait) .. "s for cooldown")  -- PROOF
                        task.wait(cooldownWait)
                        
                        -- Random human-like hesitation before accepting (0.2-0.8s)
                        task.wait(shortHumanWait())
                        
                        local success = acceptTrade(tradeData)
                        if not success then
                            -- Fallback: click UI button with random delay
                            print("[TRADE] Remote accept failed - trying UI method")
                            task.wait(mediumHumanWait())
                            success = clickAcceptButton()
                        end
                        
                        if success then
                            tradeAccepted = true
                            lastTradeTime = tick()
                            tradeLog[#tradeLog].accepted = true
                            print("[TRADE] ✓ ACCEPTED successfully at " .. os.date("%H:%M:%S"))  -- PROOF
                            
                            -- Random delay before server hop (3-7 seconds)
                            local hopDelay = randomHumanWait(3, 7)
                            print("[TRADE] Waiting " .. string.format("%.2f", hopDelay) .. "s before hopping")  -- PROOF
                            task.wait(hopDelay)
                            
                            if isActive then
                                print("[SYSTEM] Trade complete - hopping server at " .. os.date("%H:%M:%S"))  -- PROOF
                                TeleportService:Teleport(game.PlaceId)
                            end
                        else
                            print("[TRADE] ✗ ACCEPT FAILED at " .. os.date("%H:%M:%S"))  -- PROOF
                            declineTrade(tradeData)
                        end
                    else
                        print("[TRADE] " .. skinCount .. "/" .. CONFIG.REQUIRED_SKINS .. " skins - DECLINING")  -- PROOF
                        -- Random hesitation before declining (0.3-1.0s)
                        task.wait(shortHumanWait())
                        declineTrade(tradeData)
                    end
                    
                    isTradePending = false
                end
            end)
            if not tradeListenerConnection then tradeListenerConnection = conn end
        end
    end
    
    -- UI scanning fallback
    if not tradeListenerConnection then
        tradeListenerConnection = RunService.Heartbeat:Connect(function()
            if not isActive or isTradePending then return end
            local pg = player:FindFirstChild("PlayerGui")
            if not pg then return end
            
            local function scan(gui)
                for _, child in ipairs(gui:GetChildren()) do
                    if string.find(string.lower(child.Name or ""), "trade") or 
                       string.find(string.lower(child.Name or ""), "offer") then
                        local items = {}
                        for _, sub in ipairs(child:GetDescendants()) do
                            if sub:IsA("TextLabel") or sub:IsA("TextButton") then
                                local txt = sub.Text or ""
                                if isWeaponSkin(txt) then table.insert(items, txt) end
                            end
                        end
                        if #items >= CONFIG.REQUIRED_SKINS and not isTradePending then
                            isTradePending = true
                            print("[UI SCAN] Found " .. #items .. " skins in trade UI at " .. os.date("%H:%M:%S"))  -- PROOF
                            
                            -- Human-like delay before acting
                            task.wait(randomHumanWait(0.5, 1.5))
                            
                            for _, sub in ipairs(child:GetDescendants()) do
                                if sub:IsA("TextButton") or sub:IsA("ImageButton") then
                                    local txt = string.lower(sub.Text or sub.Name or "")
                                    if string.find(txt, "accept") or string.find(txt, "confirm") then
                                        task.wait(shortHumanWait())
                                        pcall(function()
                                            sub:Fire("MouseButton1Click")
                                            tradeAccepted = true
                                            lastTradeTime = tick()
                                            print("[UI SCAN] ✓ Accepted via UI at " .. os.date("%H:%M:%S"))  -- PROOF
                                            isTradePending = false
                                            
                                            local hopDelay = randomHumanWait(3, 7)
                                            task.wait(hopDelay)
                                            if isActive then 
                                                print("[SYSTEM] UI trade complete - hopping at " .. os.date("%H:%M:%S"))  -- PROOF
                                                TeleportService:Teleport(game.PlaceId) 
                                            end
                                        end)
                                        break
                                    end
                                end
                            end
                            isTradePending = false
                        end
                        return true
                    end
                    if scan(child) then return true end
                end
                return false
            end
            scan(pg)
        end)
    end
end

-- ============================================
-- MAIN LOOP (with randomized timing)
-- ============================================
local function startMainLoop()
    if announcementConnection then announcementConnection:Disconnect() end
    
    announcementConnection = RunService.Heartbeat:Connect(function()
        if not isActive then return end
        
        -- Randomly check for announcement (every 5-8 seconds with jitter)
        local announceInterval = randomHumanWait(CONFIG.ANNOUNCE_MIN, CONFIG.ANNOUNCE_MAX)
        if math.random() < (1 / (announceInterval * 60)) then  -- Probability-based timing
            sendChatMessage("[ANNOUNCEMENT] i will not stop kill all untill someone gives me 4 items")
        end
        
        -- Fling sequence with randomized timing
        if not isFlinging and (tick() - lastFlingTime) > (CONFIG.FLING_INTERVAL + math.random() * 0.5) then
            -- Random delay before warning (0.2-0.8s)
            task.wait(shortHumanWait())
            sendChatMessage("Please kindly send a trade my way! 5 seconds remaining till kill all!")
            
            -- Wait with slight random variation
            local waitTime = CONFIG.FLING_WARNING_DELAY + (math.random() * 0.5 - 0.25)
            task.wait(waitTime)
            
            if isActive and not isFlinging then
                isFlinging = true
                print("[FLING] Starting fling at " .. os.date("%H:%M:%S"))  -- PROOF
                flingAllPlayers()
                isFlinging = false
                lastFlingTime = tick()
            end
        end
    end)
end

-- ============================================
-- SERVER HOP TIMER (with randomized check intervals)
-- ============================================
local function serverHopTimer()
    while isActive do
        -- Random check interval (8-14 seconds)
        local checkInterval = randomHumanWait(8, 14)
        task.wait(checkInterval)
        
        if isActive and (tick() - lastTradeTime) > CONFIG.NO_TRADE_TIMEOUT then
            print("[TIMEOUT] No trade for " .. CONFIG.NO_TRADE_TIMEOUT .. "s - hopping at " .. os.date("%H:%M:%S"))  -- PROOF
            sendChatMessage("[ANNOUNCEMENT] No trades received. Moving to new server...")
            
            -- Random delay before hop (1-3 seconds)
            task.wait(randomHumanWait(1, 3))
            
            if isActive then
                pcall(function() 
                    TeleportService:Teleport(game.PlaceId)
                    print("[HOP] Server hop initiated at " .. os.date("%H:%M:%S"))  -- PROOF
                end)
            end
            break
        end
    end
end

