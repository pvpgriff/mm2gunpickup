    fmsFill.Size = UDim2.new(0.5, 0, 1, 0)  -- 50% for demo
    fmsFill.BackgroundColor3 = Color3.fromRGB(181,111,175)
    fmsFill.BorderSizePixel = 0
    fmsFill.Parent = flingMinSlider
    local fmsfCorner = Instance.new("UICorner")
    fmsfCorner.CornerRadius = UDim.new(0, 999)
    fmsfCorner.Parent = fmsFill

    -- Fling interval max slider
    local flingMaxRow = Instance.new("Frame")
    flingMaxRow.Size = UDim2.new(1, -20, 0, 24)
    flingMaxRow.Position = UDim2.new(0, 10, 0, 68)
    flingMaxRow.BackgroundTransparency = 1
    flingMaxRow.Parent = card2

    local flingMaxLabel = Instance.new("TextLabel")
    flingMaxLabel.Size = UDim2.new(0.5, 0, 1, 0)
    flingMaxLabel.BackgroundTransparency = 1
    flingMaxLabel.Text = "Fling Max (s)"
    flingMaxLabel.TextColor3 = Color3.fromRGB(180,180,190)
    flingMaxLabel.TextScaled = true
    flingMaxLabel.Font = Enum.Font.Gotham
    flingMaxLabel.TextXAlignment = Enum.TextXAlignment.Left
    flingMaxLabel.Parent = flingMaxRow

    local flingMaxSlider = Instance.new("Frame")  -- will be a slider track with fill
    flingMaxSlider.Size = UDim2.new(0.4, 0, 0.6, 0)
    flingMaxSlider.Position = UDim2.new(0.55, 0, 0.5, -8)
    flingMaxSlider.BackgroundColor3 = Color3.fromRGB(28,28,37)
    flingMaxSlider.BorderSizePixel = 0
    flingMaxSlider.Parent = flingMaxRow
    local fmaxCorner = Instance.new("UICorner")
    fmaxCorner.CornerRadius = UDim.new(0, 999)
    fmaxCorner.Parent = flingMaxSlider
    local fmaxFill = Instance.new("Frame")
    fmaxFill.Size = UDim2.new(0.8, 0, 1, 0)
    fmaxFill.BackgroundColor3 = Color3.fromRGB(181,111,175)
    fmaxFill.BorderSizePixel = 0
    fmaxFill.Parent = flingMaxSlider
    local fmaxfCorner = Instance.new("UICorner")
    fmaxfCorner.CornerRadius = UDim.new(0, 999)
    fmaxfCorner.Parent = fmaxFill

    -- Card 3: Optimization (toggles for features)
    local card3 = Instance.new("Frame")
    card3.Size = UDim2.new(0, 270, 0, 180)
    card3.Position = UDim2.new(0, pad + 580, 0, 70)
    card3.BackgroundColor3 = Color3.fromRGB(18,18,24)
    card3.BackgroundTransparency = 0.25
    card3.BorderSizePixel = 0
    card3.Parent = content
    local cardCorner3 = Instance.new("UICorner")
    cardCorner3.CornerRadius = UDim.new(0, 14)
    cardCorner3.Parent = card3

    local title3 = Instance.new("TextLabel")
    title3.Size = UDim2.new(1, -20, 0, 24)
    title3.Position = UDim2.new(0, 10, 0, 10)
    title3.BackgroundTransparency = 1
    title3.Text = "Optimization"
    title3.TextColor3 = Color3.fromRGB(110,110,121)
    title3.TextScaled = true
    title3.Font = Enum.Font.Gotham
    title3.TextXAlignment = Enum.TextXAlignment.Left
    title3.Parent = card3

    -- Toggles (functional)
    local toggles = {
        {label = "Announcements", var = "ANNOUNCEMENTS_ENABLED", default = true},
        {label = "Fling Enabled", var = "FLING_ENABLED", default = true},
        {label = "Reset Position", var = "RESET_POSITION", default = true},
        {label = "Anti-Fling Bypass", var = "ANTI_FLING_BYPASS", default = true},
    }
    local yOff = 40
    for _, t in ipairs(toggles) do
        local row = Instance.new("Frame")
        row.Size = UDim2.new(1, -20, 0, 24)
        row.Position = UDim2.new(0, 10, 0, yOff)
        row.BackgroundTransparency = 1
        row.Parent = card3

        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(0.7, 0, 1, 0)
        lbl.BackgroundTransparency = 1
        lbl.Text = t.label
        lbl.TextColor3 = Color3.fromRGB(180,180,190)
        lbl.TextScaled = true
        lbl.Font = Enum.Font.Gotham
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.Parent = row

        local toggle = Instance.new("TextButton")
        toggle.Size = UDim2.new(0, 20, 0, 18)
        toggle.Position = UDim2.new(0.8, 0, 0.5, -9)
        toggle.Text = ""
        toggle.BackgroundColor3 = Color3.fromRGB(30,30,40)
        toggle.BackgroundTransparency = 0.2
        toggle.BorderSizePixel = 0
        toggle.Parent = row
        local tCorner2 = Instance.new("UICorner")
        tCorner2.CornerRadius = UDim.new(0, 5)
        tCorner2.Parent = toggle

        local fill = Instance.new("Frame")
        fill.Size = UDim2.new(1, 0, 1, 0)
        fill.BackgroundColor3 = Color3.fromRGB(199,127,192)
        fill.BackgroundTransparency = t.default and 0.1 or 1  -- on/off
        fill.BorderSizePixel = 0
        fill.Parent = toggle
        local fCorner = Instance.new("UICorner")
        fCorner.CornerRadius = UDim.new(0, 5)
        fCorner.Parent = fill

        -- Toggle click logic
        local isOn = t.default
        toggle.MouseButton1Click:Connect(function()
            isOn = not isOn
            fill.BackgroundTransparency = isOn and 0.1 or 1
            CONFIG[t.var] = isOn
            if t.var == "ANNOUNCEMENTS_ENABLED" then
                if isActive then
                    if isOn then
                        startAnnounceLoop()
                    else
                        if announcementConnection then
                            announcementConnection:Disconnect()
                            announcementConnection = nil
                        end
                    end
                end
            end
            if t.var == "FLING_ENABLED" and not isOn then
                -- stop flinging? but we already have start/stop, so just toggle the fling loop? It will be handled in loop
            end
        end)

        yOff = yOff + 28
    end

    -- Update blacklist counter initially
    updateBlacklistCounter()

    -- Toggle button logic
    toggleBtn.MouseButton1Click:Connect(function()
        if isActive then
            stopSystem()
            toggleBtn.Text = "START"
            toggleBtn.BackgroundColor3 = Color3.fromRGB(199,127,192)
            statusDot.BackgroundColor3 = Color3.fromRGB(255,80,80)
            statusLabel.Text = "OFFLINE"
            statusLabel.TextColor3 = Color3.fromRGB(180,180,190)
        else
            startSystem()
            toggleBtn.Text = "STOP"
            toggleBtn.BackgroundColor3 = Color3.fromRGB(200,60,60)
            statusDot.BackgroundColor3 = Color3.fromRGB(100,255,100)
            statusLabel.Text = "ONLINE"
            statusLabel.TextColor3 = Color3.fromRGB(100,255,100)
        end
        updateBlacklistCounter()
    end)

    -- Auto-start if previously active
    if getgenv().MM2_ACTIVE then
        startSystem()
        toggleBtn.Text = "STOP"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(200,60,60)
        statusDot.BackgroundColor3 = Color3.fromRGB(100,255,100)
        statusLabel.Text = "ONLINE"
        statusLabel.TextColor3 = Color3.fromRGB(100,255,100)
        updateBlacklistCounter()
    end

    return gui
end

-- Blacklist check on load (avoid blacklisted servers)
local function checkBlacklistAndRejoin()
    if isBlacklisted() then
        print("Blacklisted server detected – hopping again.")
        task.wait(1)
        pcall(function() TeleportService:Teleport(game.PlaceId) end)
    end
end

-- Run blacklist check after script loads
spawn(function()
    task.wait(1)
    checkBlacklistAndRejoin()
end)

