        local fCorner = Instance.new("UICorner")
        fCorner.CornerRadius = UDim.new(0, 6)
        fCorner.Parent = fill

        local isOn = data.default
        toggle.MouseButton1Click:Connect(function()
            isOn = not isOn
            local targetTrans = isOn and 0.2 or 1
            TweenService:Create(fill, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                BackgroundTransparency = targetTrans
            }):Play()
            CONFIG[data.var] = isOn
            if data.var == "ANNOUNCEMENTS" then
                if isActive then
                    if isOn then startAnnounceLoop() else
                        if announcementConnection then announcementConnection:Disconnect(); announcementConnection = nil end
                    end
                end
            end
        end)
    end

    -- === FLING FORCE SLIDER ===
    local sliderRow = Instance.new("Frame")
    sliderRow.Size = UDim2.new(1, 0, 0, 32)
    sliderRow.Position = UDim2.new(0, 0, 0, 134)
    sliderRow.BackgroundTransparency = 1
    sliderRow.Parent = content

    local forceLabel = Instance.new("TextLabel")
    forceLabel.Size = UDim2.new(0.22, 0, 1, 0)
    forceLabel.BackgroundTransparency = 1
    forceLabel.Text = "Force"
    forceLabel.TextColor3 = Color3.fromRGB(180, 180, 195)
    forceLabel.TextScaled = true
    forceLabel.Font = Enum.Font.Gotham
    forceLabel.TextXAlignment = Enum.TextXAlignment.Left
    forceLabel.Parent = sliderRow

    -- Slider track
    local sliderTrack = Instance.new("TextButton")
    sliderTrack.Size = UDim2.new(0.48, 0, 0.6, 0)
    sliderTrack.Position = UDim2.new(0.24, 0, 0.5, -9)
    sliderTrack.BackgroundColor3 = Color3.fromRGB(30, 30, 45)
    sliderTrack.BackgroundTransparency = 0.3
    sliderTrack.BorderSizePixel = 0
    sliderTrack.Parent = sliderRow
    local stCorner = Instance.new("UICorner")
    stCorner.CornerRadius = UDim.new(0, 999)
    stCorner.Parent = sliderTrack

    -- Slider fill (animated)
    local sliderFill = Instance.new("Frame")
    sliderFill.Size = UDim2.new(0.5, 0, 1, 0)
    sliderFill.BackgroundColor3 = Color3.fromRGB(160, 100, 220)
    sliderFill.BackgroundTransparency = 0.2
    sliderFill.BorderSizePixel = 0
    sliderFill.Parent = sliderTrack
    local sfCorner = Instance.new("UICorner")
    sfCorner.CornerRadius = UDim.new(0, 999)
    sfCorner.Parent = sliderFill

    -- Slider handle (subtle)
    local handle = Instance.new("Frame")
    handle.Size = UDim2.new(0, 12, 0, 12)
    handle.Position = UDim2.new(0.5, -6, 0.5, -6)
    handle.BackgroundColor3 = Color3.fromRGB(200, 160, 255)
    handle.BackgroundTransparency = 0.3
    handle.BorderSizePixel = 0
    handle.Parent = sliderTrack
    local hCorner2 = Instance.new("UICorner")
    hCorner2.CornerRadius = UDim.new(1, 0)
    hCorner2.Parent = handle

    -- Force value display
    local forceValue = Instance.new("TextLabel")
    forceValue.Size = UDim2.new(0.2, 0, 1, 0)
    forceValue.Position = UDim2.new(0.75, 0, 0, 0)
    forceValue.BackgroundTransparency = 1
    forceValue.Text = "5.0e7"
    forceValue.TextColor3 = Color3.fromRGB(160, 160, 185)
    forceValue.TextScaled = true
    forceValue.Font = Enum.Font.Gotham
    forceValue.TextXAlignment = Enum.TextXAlignment.Left
    forceValue.Name = "ForceValue"
    forceValue.Parent = sliderRow

    -- === SLIDER DRAG LOGIC ===
    local dragging = false
    local function updateSliderFromMouse(x)
        local trackAbsPos = sliderTrack.AbsolutePosition
        local trackSize = sliderTrack.AbsoluteSize
        local relX = math.clamp((x - trackAbsPos.X) / trackSize.X, 0, 1)
        sliderFill.Size = UDim2.new(relX, 0, 1, 0)
        handle.Position = UDim2.new(relX, -6, 0.5, -6)
        local force = relX * 90000000
        if force < 1000000 then force = 1000000 end
        CONFIG.FLING_FORCE = force
        forceValue.Text = string.format("%.1e", force)
    end

    sliderTrack.MouseButton1Down:Connect(function(x, y)
        dragging = true
        updateSliderFromMouse(x)
    end)

    UserInputService.InputChanged:Connect(function(input, processed)
        if processed then return end
        if input.UserInputType == Enum.UserInputType.MouseMovement and dragging then
            updateSliderFromMouse(input.Position.X)
        end
    end)

    UserInputService.InputEnded:Connect(function(input, processed)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    -- === START/STOP LOGIC ===
    toggleBtn.MouseButton1Click:Connect(function()
        if isActive then
            stopSystem()
            toggleBtn.Text = "START"
            toggleBtn.BackgroundColor3 = Color3.fromRGB(140, 90, 200)
            dot.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
            dotContainer.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
            statusText.Text = "OFFLINE"
            statusText.TextColor3 = Color3.fromRGB(160, 160, 175)
        else
            startSystem()
            toggleBtn.Text = "STOP"
            toggleBtn.BackgroundColor3 = Color3.fromRGB(200, 60, 60)
            dot.BackgroundColor3 = Color3.fromRGB(100, 255, 100)
            dotContainer.BackgroundColor3 = Color3.fromRGB(100, 255, 100)
            statusText.Text = "ONLINE"
            statusText.TextColor3 = Color3.fromRGB(100, 255, 100)
        end
        updateBlacklistCounter()
    end)

    -- === AUTO-START ===
    if getgenv().MM2_ACTIVE then
        startSystem()
        toggleBtn.Text = "STOP"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(200, 60, 60)
        dot.BackgroundColor3 = Color3.fromRGB(100, 255, 100)
        dotContainer.BackgroundColor3 = Color3.fromRGB(100, 255, 100)
        statusText.Text = "ONLINE"
        statusText.TextColor3 = Color3.fromRGB(100, 255, 100)
        updateBlacklistCounter()
    end

    updateBlacklistCounter()
    return gui
end

