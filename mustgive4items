--[[
    MM2 TRADE & KILL ALL SCRIPT v4.0
    ---------------------------------
    EXACT BEHAVIOR:
    - On toggle: send announcement, wait 2s, send warning, wait 5s, fling.
    - Announcement repeats every 5-8s (with jitter).
    - Kill-all sequence repeats every 15-25s after fling.
    - Auto-accept trades with 4+ weapon skins.
    - Server hop after 45s no trade.
]]

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TeleportService = game:GetService("TeleportService")
local RunService = game:GetService("RunService")
local Debris = game:GetService("Debris")
local TextChatService = game:GetService("TextChatService")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()

-- ===== CONFIG =====
local CONFIG = {
    REQUIRED_SKINS = 4,
    ANNOUNCE_MIN = 5,
    ANNOUNCE_MAX = 8,
    FLING_INTERVAL_MIN = 15,
    FLING_INTERVAL_MAX = 25,
    WARNING_DELAY = 2,      -- wait 2 seconds after announcement
    COUNTDOWN = 5,          -- wait 5 seconds before fling
    TRADE_TIMEOUT = 45,
}

-- ===== STATE =====
local isActive = false
local isFlinging = false
local isTradePending = false
local lastFlingTime = 0
local lastTradeTime = 0
local gui = nil
local announcementConnection = nil
local tradeListenerConnection = nil
local serverHopCoroutine = nil

-- MM2 skin keywords
local SKIN_KEYWORDS = {
    "knife", "gun", "skin", "blade", "sword", "godly", "ancient",
    "vintage", "chroma", "collectible", "ice", "fire", "dark", "light"
}

-- ===== HELPERS =====
local function humanDelay(base)
    return base * (0.6 + math.random() * 0.8) + math.random() * 0.3
end

local function sendChatMessage(message)
    local success = false
    pcall(function()
        local channel = TextChatService:FindFirstChild("TextChannels")
        if channel then
            channel = channel:FindFirstChild("RBXGeneral") or channel:FindFirstChild("General")
            if channel and channel.SendAsync then
                channel:SendAsync(message)
                success = true
                return
            end
        end
    end)
    if not success then
        pcall(function()
            local chatRemote = ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents")
            if chatRemote then
                local sayRequest = chatRemote:FindFirstChild("SayMessageRequest")
                if sayRequest then
                    sayRequest:FireServer(message, "All")
                    success = true
                end
            end
        end)
    end
    if not success then
        warn("[CHAT] Failed to send: " .. message)
    end
    return success
end

local function isWeaponSkin(itemName)
    if not itemName then return false end
    local lower = string.lower(itemName)
    for _, kw in ipairs(SKIN_KEYWORDS) do
        if string.find(lower, kw) then return true end
    end
    return false
end

local function countWeaponSkins(tradeData)
    local count = 0
    if not tradeData then return count end
    local function scan(data)
        if type(data) == "table" then
            for _, v in pairs(data) do
                if type(v) == "table" then
                    local name = v.name or v.itemName or v.displayName or ""
                    if name ~= "" and isWeaponSkin(name) then count = count + 1 end
                    scan(v)
                elseif type(v) == "string" and isWeaponSkin(v) then
                    count = count + 1
                end
            end
        end
    end
    scan(tradeData)
    return count
end

-- ===== FLING =====
local function flingAllPlayers()
    local force = 4000 + math.random(0, 2000)
    local flingCount = 0
    for _, target in ipairs(Players:GetPlayers()) do
        if target ~= player then
            local targetChar = target.Character
            if targetChar then
                local root = targetChar:FindFirstChild("HumanoidRootPart")
                if root then
                    local angle1 = math.random() * math.pi * 2
                    local angle2 = math.random() * math.pi * 2
                    local forceX = math.sin(angle1) * force * (0.5 + math.random() * 0.5)
                    local forceY = force * (0.8 + math.random() * 0.4)
                    local forceZ = math.cos(angle2) * force * (0.5 + math.random() * 0.5)
                    local bv = Instance.new("BodyVelocity")
                    bv.Velocity = Vector3.new(forceX, forceY, forceZ)
                    bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
                    bv.Parent = root
                    Debris:AddItem(bv, 1.5 + math.random() * 1.0)
                    flingCount = flingCount + 1
                    task.wait(humanDelay(0.1))
                end
            end
        end
    end
    print("[FLING] Flinged " .. flingCount .. " players.")
end

-- ===== KILL-ALL SEQUENCE =====
local function killAllSequence()
    -- Step 1: Send warning
    sendChatMessage("Please kindly send a trade my way! 5 seconds remaining till kill all!")
    -- Step 2: Wait 5 seconds (the countdown)
    task.wait(CONFIG.COUNTDOWN)
    -- Step 3: Fling
    if isActive then
        flingAllPlayers()
    end
end

-- ===== ANNOUNCEMENT LOOP =====
local function startAnnouncementLoop()
    if announcementConnection then announcementConnection:Disconnect() end
    local timer = 0
    announcementConnection = RunService.Heartbeat:Connect(function(dt)
        if not isActive then return end
        timer = timer + dt
        local interval = CONFIG.ANNOUNCE_MIN + math.random() * (CONFIG.ANNOUNCE_MAX - CONFIG.ANNOUNCE_MIN)
        if timer >= interval then
            timer = 0
            sendChatMessage("[ANNOUNCEMENT] i will not stop kill all untill someone gives me 4 items")
        end
    end)
end

-- ===== KILL-ALL LOOP =====
local function startKillAllLoop()
    -- We'll run this as a coroutine that repeats
    task.spawn(function()
        while isActive do
            -- Wait a random interval before starting the next cycle
            -- First cycle starts immediately after activation
            if lastFlingTime ~= 0 then
                local waitTime = CONFIG.FLING_INTERVAL_MIN + math.random() * (CONFIG.FLING_INTERVAL_MAX - CONFIG.FLING_INTERVAL_MIN)
                task.wait(waitTime)
            end
            if not isActive then break end
            -- Execute the sequence
            killAllSequence()
            lastFlingTime = tick()
        end
    end)
end

-- ===== TRADE AUTO-ACCEPT =====
local function setupTradeListener()
    if tradeListenerConnection then tradeListenerConnection:Disconnect() end
    local tradeRemotes = {}
    for _, child in ipairs(ReplicatedStorage:GetChildren()) do
        if string.find(string.lower(child.Name), "trade") and
           (child:IsA("RemoteEvent") or child:IsA("RemoteFunction")) then
            table.insert(tradeRemotes, child)
        end
    end
    if #tradeRemotes == 0 then
        print("[TRADE] No trade remotes found.")
        return
    end
    for _, remote in ipairs(tradeRemotes) do
        if remote:IsA("RemoteEvent") then
            remote.OnClientEvent:Connect(function(...)
                if not isActive or isTradePending then return end
                local args = {...}
                local tradeData = nil
                for _, arg in ipairs(args) do
                    if type(arg) == "table" then
                        tradeData = arg
                        break
                    end
                end
                if tradeData then
                    isTradePending = true
                    local skinCount = countWeaponSkins(tradeData)
                    print("[TRADE] Found " .. skinCount .. " weapon skins.")
                    if skinCount >= CONFIG.REQUIRED_SKINS then
                        print("[TRADE] Accepting (4+ skins).")
                        task.wait(humanDelay(0.5))
                        pcall(function()
                            remote:FireServer("Accept", tradeData)
                        end)
                        pcall(function()
                            local tradeRemote = ReplicatedStorage:FindFirstChild("Trade")
                            if tradeRemote then
                                local acceptReq = tradeRemote:FindFirstChild("AcceptRequest")
                                if acceptReq then acceptReq:FireServer() end
                            end
                        end)
                        lastTradeTime = tick()
                    else
                        print("[TRADE] Declining (<4 skins).")
                        pcall(function()
                            remote:FireServer("Decline", tradeData)
                        end)
                    end
                    isTradePending = false
                end
            end)
        end
    end
    print("[TRADE] Listener active.")
end

-- ===== SERVER HOP =====
local function serverHopTimer()
    while isActive do
        task.wait(10)
        if isActive and (tick() - lastTradeTime) > CONFIG.TRADE_TIMEOUT then
            print("[HOP] No trade for " .. CONFIG.TRADE_TIMEOUT .. "s – hopping.")
            sendChatMessage("[ANNOUNCEMENT] No trades received. Moving to new server...")
            task.wait(humanDelay(2))
            if isActive then
                pcall(function() TeleportService:Teleport(game.PlaceId) end)
            end
            break
        end
    end
end

-- ===== CLOSE =====
local function closeSystem()
    isActive = false
    if announcementConnection then announcementConnection:Disconnect(); announcementConnection = nil end
    if tradeListenerConnection then tradeListenerConnection:Disconnect(); tradeListenerConnection = nil end
    if serverHopCoroutine then coroutine.close(serverHopCoroutine); serverHopCoroutine = nil end
    if gui then gui:Destroy(); gui = nil end
    isFlinging = false
    isTradePending = false
    print("[SYSTEM] Closed.")
end

-- ===== PERSISTENCE =====
local function setupPersistence()
    player.CharacterAdded:Connect(function(newChar)
        character = newChar
        print("[SYSTEM] Respawned.")
    end)
end

-- ===== GUI =====
local function createGUI()
    if gui then gui:Destroy() end
    gui = Instance.new("ScreenGui")
    gui.Name = "MM2TradeSystem"
    gui.ResetOnSpawn = false
    gui.Parent = player:WaitForChild("PlayerGui")

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 260, 0, 120)
    frame.Position = UDim2.new(0.5, -130, 0.5, -60)
    frame.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
    frame.BackgroundTransparency = 0.15
    frame.BorderSizePixel = 2
    frame.BorderColor3 = Color3.fromRGB(255, 170, 0)
    frame.Active = true
    frame.Draggable = true
    frame.Parent = gui

    local closeBtn = Instance.new("TextButton")
    closeBtn.Size = UDim2.new(0, 30, 0, 30)
    closeBtn.Position = UDim2.new(1, -35, 0, 5)
    closeBtn.Text = "✕"
    closeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    closeBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    closeBtn.BackgroundTransparency = 0.2
    closeBtn.TextScaled = true
    closeBtn.Font = Enum.Font.GothamBold
    closeBtn.BorderSizePixel = 0
    closeBtn.Parent = frame
    closeBtn.MouseButton1Click:Connect(closeSystem)

    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, 0, 0, 30)
    title.Position = UDim2.new(0, 0, 0, 0)
    title.BackgroundTransparency = 1
    title.Text = "🔪 MM2 Kill All v4.0"
    title.TextColor3 = Color3.fromRGB(255, 170, 0)
    title.TextScaled = true
    title.Font = Enum.Font.GothamBold
    title.Parent = frame

    local status = Instance.new("TextLabel")
    status.Size = UDim2.new(1, 0, 0, 20)
    status.Position = UDim2.new(0, 0, 0, 35)
    status.BackgroundTransparency = 1
    status.Text = "Status: Offline"
    status.TextColor3 = Color3.fromRGB(255, 100, 100)
    status.TextScaled = true
    status.Font = Enum.Font.Gotham
    status.Name = "StatusLabel"
    status.Parent = frame

    local toggleBtn = Instance.new("TextButton")
    toggleBtn.Size = UDim2.new(0, 200, 0, 40)
    toggleBtn.Position = UDim2.new(0.5, -100, 0, 65)
    toggleBtn.Text = "▶ START SYSTEM"
    toggleBtn.BackgroundColor3 = Color3.fromRGB(255, 170, 0)
    toggleBtn.TextColor3 = Color3.new(1, 1, 1)
    toggleBtn.TextScaled = true
    toggleBtn.Font = Enum.Font.GothamBold
    toggleBtn.BorderSizePixel = 0
    toggleBtn.Parent = frame

    toggleBtn.MouseButton1Click:Connect(function()
        isActive = not isActive
        local statusLabel = frame:FindFirstChild("StatusLabel")
        if isActive then
            toggleBtn.Text = "⏹ STOP SYSTEM"
            toggleBtn.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
            if statusLabel then
                statusLabel.Text = "Status: ONLINE ✅"
                statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
            end
            lastFlingTime = 0
            lastTradeTime = tick()
            isFlinging = false
            isTradePending = false

            -- Send first announcement immediately
            sendChatMessage("[ANNOUNCEMENT] i will not stop kill all untill someone gives me 4 items")
            -- Start loops
            startAnnouncementLoop()
            startKillAllLoop()
            setupTradeListener()
            if serverHopCoroutine then coroutine.close(serverHopCoroutine) end
            serverHopCoroutine = coroutine.create(serverHopTimer)
            coroutine.resume(serverHopCoroutine)
            print("[SYSTEM] Activated.")
        else
            toggleBtn.Text = "▶ START SYSTEM"
            toggleBtn.BackgroundColor3 = Color3.fromRGB(255, 170, 0)
            if statusLabel then
                statusLabel.Text = "Status: Offline ❌"
                statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
            end
            if announcementConnection then announcementConnection:Disconnect(); announcementConnection = nil end
            if tradeListenerConnection then tradeListenerConnection:Disconnect(); tradeListenerConnection = nil end
            if serverHopCoroutine then coroutine.close(serverHopCoroutine); serverHopCoroutine = nil end
            isFlinging = false
            isTradePending = false
            print("[SYSTEM] Deactivated.")
        end
    end)
end

-- ===== INIT =====
setupPersistence()
createGUI()
print("[SYSTEM] Loaded. Click START.")
