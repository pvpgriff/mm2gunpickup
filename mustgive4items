-- ===== PERSISTENCE WATCHDOG =====
if not getgenv().WATCHDOG_RUNNING then
    getgenv().WATCHDOG_RUNNING = true
    spawn(function()
        local currentPlaceId = game.PlaceId
        while true do
            task.wait(5)
            if game.PlaceId ~= currentPlaceId then
