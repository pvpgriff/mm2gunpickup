-- ============================================
-- HUMAN-LIKE RANDOMIZATION FUNCTIONS
-- ============================================

-- Generate a human-like random delay (jitter)
-- Simulates human reaction time with natural variation
local function humanDelay(baseDelay)
    -- Add random jitter: ±40% variation with a minimum floor
    local jitter = baseDelay * (0.6 + math.random() * 0.8)
    -- Add small extra random delay for natural feel
    local extra = math.random() * 0.5
    return jitter + extra
end

-- Generate a random delay between min and max seconds (human-like)
local function randomHumanWait(minSec, maxSec)
    local base = minSec + math.random() * (maxSec - minSec)
    return humanDelay(base)
end

-- Short random wait (for between actions)
local function shortHumanWait()
    return humanDelay(CONFIG.MIN_HUMAN_DELAY + math.random() * 0.5)
end

-- Medium random wait (for between major actions)
local function mediumHumanWait()
    return humanDelay(0.5 + math.random() * 1.0)
end

