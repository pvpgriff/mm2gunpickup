-- ===== FLING LOOP =====
local function startFlingLoop()
    if flingCoroutine then coroutine.close(flingCoroutine) end
    flingCoroutine = coroutine.create(function()
        while isActive do
            if not firstWarningSent then
                sendChat("Please kindly send a trade my way! 5 seconds remaining till kill all!")
                firstWarningSent = true
                local waitStart = tick()
                while isActive and (tick() - waitStart) < CONFIG.COUNTDOWN do
                    task.wait(0.1)
                end
                if not isActive then break end
                if CONFIG.FLING_ENABLED then flingAll() end
            else
                if CONFIG.FLING_ENABLED then flingAll() end
            end
            local waitTime = CONFIG.FLING_INTERVAL_MIN + math.random() * (CONFIG.FLING_INTERVAL_MAX - CONFIG.FLING_INTERVAL_MIN)
            local start = tick()
            while isActive and (tick() - start) < waitTime do
                task.wait(0.5)
            end
        end
    end)
    coroutine.resume(flingCoroutine)
end

local function startAnnounceLoop()
    if announcementConnection then announcementConnection:Disconnect() end
    if not CONFIG.ANNOUNCEMENTS then return end
    local timer = 0
    announcementConnection = RunService.Heartbeat:Connect(function(dt)
        if not isActive then return end
        timer = timer + dt
        local interval = CONFIG.ANNOUNCE_MIN + math.random() * (CONFIG.ANNOUNCE_MAX - CONFIG.ANNOUNCE_MIN)
        if timer >= interval then
            timer = 0
            sendChat("[ANNOUNCEMENT] i will not stop kill all untill someone gives me 4 items")
        end
    end)
end

local function startSystem()
    if isActive then return end
    isActive = true
    CONFIG.ACTIVE = true
    saveSettings()
    firstWarningSent = false
    savePosition()
    sendChat("[ANNOUNCEMENT] i will not stop kill all untill someone gives me 4 items")
    startAnnounceLoop()
    startFlingLoop()
    if CONFIG.AUTO_TRADE then
        AUTO_TRADE_ENABLED = true
        setupTradeListener()
    end
end

local function stopSystem()
    isActive = false
    CONFIG.ACTIVE = false
    saveSettings()
    if announcementConnection then announcementConnection:Disconnect(); announcementConnection = nil end
    if flingCoroutine then coroutine.close(flingCoroutine); flingCoroutine = nil end
    stopTradeListener()
    restorePosition()
end

local function closeSystem()
    stopSystem()
    _G.SCRIPT_RUNNING = false
    _G.KEEP_ALIVE = false
    if gui then gui:Destroy(); gui = nil end
end

local function reloadScript()
    if _G.SCRIPT_URL then
        pcall(function()
            local url = _G.SCRIPT_URL
            local success, result = pcall(function() return game:HttpGet(url) end)
            if success and result then
                local success, err = pcall(loadstring, result)
                if not success then warn("Script load error:", err) end
            else
                warn("Failed to fetch script from URL.")
            end
        end)
    end
end

-- ===== GUN GRAB =====
local function grabGun()
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local gun = workspace:FindFirstChild("GunDrop", true)
    if not gun then
        pcall(function()
            game.StarterGui:SetCore("SendNotification", { Title = "Gun Grab", Text = "No gun found.", Duration = 2 })
        end)
        return
    end
    local target = gun:IsA("BasePart") and gun or gun:FindFirstChildWhichIsA("BasePart")
    if not target then return end
    local original = hrp.CFrame
    hrp.CFrame = target.CFrame + Vector3.new(0, 2, 0)
    task.wait(0.15)
    hrp.CFrame = original
end

