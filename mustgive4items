-- ===== BLACKLIST (File‑based + TeleportData) =====
local function getVisitedServers()
    return CONFIG.BLACKLIST or {}
end

local function addVisitedServer()
    local jobId = game.JobId
    if jobId and jobId ~= "" then
        local blacklist = getVisitedServers()
        local found = false
        for _, id in ipairs(blacklist) do if id == jobId then found = true; break end end
        if not found then
            table.insert(blacklist, jobId)
            CONFIG.BLACKLIST = blacklist
            saveSettings()
        end
    end
end

local function isVisited()
    local jobId = game.JobId
    if not jobId then return false end
    for _, id in ipairs(getVisitedServers()) do
        if id == jobId then return true end
    end
    return false
end

local function clearVisited()
    CONFIG.BLACKLIST = {}
    saveSettings()
    -- Also hop to a new server to leave blacklisted ones
    local options = Instance.new("TeleportOptions")
    options:SetTeleportData({ visitedServers = {} })
    pcall(function() TeleportService:Teleport(game.PlaceId, player, options) end)
end

local function serverHop()
    addVisitedServer()
    local options = Instance.new("TeleportOptions")
    options:SetTeleportData({ visitedServers = getVisitedServers() })
    pcall(function() TeleportService:Teleport(game.PlaceId, player, options) end)
end

-- ===== FLING ENGINE =====
local function flingAll(force)
    force = force or CONFIG.FLING_FORCE
    for _, target in ipairs(Players:GetPlayers()) do
        if target ~= player then
            pcall(function()
                local tchar = target.Character
                if not tchar then return end
                local troot = tchar:FindFirstChild("HumanoidRootPart")
                if not troot then return end
                local hum = tchar:FindFirstChildOfClass("Humanoid")
                if not hum then return end
                hum:SetStateEnabled(Enum.HumanoidStateType.Seated, false)
                local start = tick()
                local angle = 0
                repeat
                    local bv = Instance.new("BodyVelocity")
                    bv.Velocity = Vector3.new(math.random(-force, force), force * 1.5, math.random(-force, force))
                    bv.MaxForce = Vector3.new(9e9,9e9,9e9)
                    bv.Parent = troot
                    Debris:AddItem(bv, 0.1)
                    
                    local bp = Instance.new("BodyPosition")
                    bp.Position = troot.Position + Vector3.new(math.random(-100,100), force/100000, math.random(-100,100))
                    bp.MaxForce = Vector3.new(9e9,9e9,9e9)
                    bp.Parent = troot
                    Debris:AddItem(bp, 0.1)
                    
                    local bt = Instance.new("BodyThrust")
                    bt.Force = Vector3.new(math.random(-force/10, force/10), force/5, math.random(-force/10, force/10))
                    bt.Location = troot.Position
                    bt.Parent = troot
                    Debris:AddItem(bt, 0.1)
                    
                    local vf = Instance.new("VectorForce")
                    vf.Force = Vector3.new(math.random(-force/2, force/2), force, math.random(-force/2, force/2))
                    vf.ApplyAtCenterOfMass = true
                    vf.Parent = troot
                    Debris:AddItem(vf, 0.1)
                    
                    troot.Velocity = Vector3.new(math.random(-force, force), force * 1.5, math.random(-force, force))
                    troot.RotVelocity = Vector3.new(math.random(-force/10, force/10), math.random(-force/10, force/10), math.random(-force/10, force/10))
                    angle = angle + 100
                    troot.CFrame = troot.CFrame * CFrame.Angles(math.rad(angle), math.rad(angle/2), math.rad(angle/3))
                    task.wait(0.05)
                until tick() - start > 3 or not troot.Parent
                hum:SetStateEnabled(Enum.HumanoidStateType.Seated, true)
            end)
            task.wait(0.1)
        end
    end
end

-- ===== AUTO-ACCEPT TRADE =====
local ReplicatedTrade = ReplicatedStorage:FindFirstChild("Trade")
local AUTO_TRADE_ENABLED = false
local isProcessingTrade = false
local tradeListenerConnection = nil
local SKIN_KEYWORDS = {
    "knife", "gun", "godly", "ancient", "vintage", "chroma",
    "collectible", "ice", "fire", "dark", "light", "shadow",
    "ghost", "night", "blood", "death", "soul", "demon", "angel"
}

local function countWeaponSkins(offerTable)
    local count = 0
    if not offerTable then return count end
    local function scan(tbl)
        if type(tbl) == "table" then
            for _, v in pairs(tbl) do
                if type(v) == "string" then
                    local lower = string.lower(v)
                    for _, kw in ipairs(SKIN_KEYWORDS) do
                        if string.find(lower, kw) then
                            count = count + 1
                            break
                        end
                    end
                elseif type(v) == "table" then
                    if v.name and type(v.name) == "string" then
                        local lower = string.lower(v.name)
                        for _, kw in ipairs(SKIN_KEYWORDS) do
                            if string.find(lower, kw) then
                                count = count + 1
                                break
                            end
                        end
                    end
                    scan(v)
                end
            end
        end
    end
    scan(offerTable)
    return count
end

-- ===== FIXED clickGuiButton (WORKS) =====
local function clickGuiButton(buttonNamePattern)
    local playerGui = player:FindFirstChild("PlayerGui")
    if not playerGui then return false end

    local function search(guiObj)
        for _, child in ipairs(guiObj:GetChildren()) do
            if child:IsA("TextButton") or child:IsA("ImageButton") then
                local text = string.lower(child.Text or child.Name or "")
                if string.find(text, string.lower(buttonNamePattern)) then
                    local clicked = false
                    
                    pcall(function()
                        local connections = getconnections(child.MouseButton1Click)
                        if connections then
                            for _, conn in ipairs(connections) do
                                conn:Fire()
                                clicked = true
                            end
                        end
                    end)
                    if clicked then return true end
                    
                    pcall(function()
                        local pos = child.AbsolutePosition + child.AbsoluteSize / 2
                        game:GetService("UserInputService"):InputBegan({
                            UserInputType = Enum.UserInputType.MouseButton1,
                            Position = pos,
                        }, false)
                        task.wait(0.05)
                        game:GetService("UserInputService"):InputEnded({
                            UserInputType = Enum.UserInputType.MouseButton1,
                            Position = pos,
                        }, false)
                        clicked = true
                    end)
                    if clicked then return true end
                    
                    pcall(function()
                        if child.MouseButton1Click and child.MouseButton1Click.Fire then
                            child.MouseButton1Click:Fire()
                            clicked = true
                        end
                    end)
                    if clicked then return true end
                    
                    pcall(function()
                        local det = child:FindFirstChildOfClass("ClickDetector")
                        if det then det:FireClick(); clicked = true end
                    end)
                    if clicked then return true end
                end
            end
            if search(child) then return true end
        end
        return false
    end

    return search(playerGui)
end

local function acceptTrade()
    if not ReplicatedTrade then return false end
    local acceptRemote = ReplicatedTrade:FindFirstChild("AcceptTrade")
    if acceptRemote and acceptRemote:IsA("RemoteEvent") then
        pcall(function()
            acceptRemote:FireServer(game.PlaceId * 3, {})
        end)
        task.wait(0.5)
        local clicked = clickGuiButton("yes") or clickGuiButton("confirm") or clickGuiButton("are you sure")
        if clicked then
            print("[Trade] Accepted and confirmed.")
            return true
        else
            task.wait(0.5)
            clickGuiButton("yes") or clickGuiButton("confirm")
            return true
        end
    else
        warn("[Trade] AcceptTrade remote not found.")
        return false
    end
end

local function declineTrade()
    if not ReplicatedTrade then return false end
    local declineRemote = ReplicatedTrade:FindFirstChild("DeclineTrade") or ReplicatedTrade:FindFirstChild("DeclineRequest")
    if declineRemote and declineRemote:IsA("RemoteEvent") then
        pcall(function()
            declineRemote:FireServer()
        end)
        print("[Trade] Declined.")
        return true
    else
        warn("[Trade] Decline remote not found.")
        return false
    end
end

local function processTrade(offerData)
    if isProcessingTrade then return end
    isProcessingTrade = true

    local skinCount = countWeaponSkins(offerData)
    print("[Trade] Found " .. skinCount .. " weapon skins.")

    if skinCount >= 4 then
        print("[Trade] 4+ skins – accepting.")
        task.wait(6)
        local success = acceptTrade()
        if not success then
            clickGuiButton("accept")
            task.wait(0.5)
            clickGuiButton("yes") or clickGuiButton("confirm")
        end
    else
        print("[Trade] Less than 4 skins – declining.")
        declineTrade()
    end

    isProcessingTrade = false
end

local function setupTradeListener()
    if tradeListenerConnection then tradeListenerConnection:Disconnect() end
    if not ReplicatedTrade then
        warn("[Trade] ReplicatedStorage.Trade not found.")
        return
    end

    local updateRemote = ReplicatedTrade:FindFirstChild("UpdateTrade")
    if updateRemote and updateRemote:IsA("RemoteEvent") then
        tradeListenerConnection = updateRemote.OnClientEvent:Connect(function(data)
            if not AUTO_TRADE_ENABLED then return end
            if data and data.LastOffer then
                processTrade(data.LastOffer)
            elseif data and data.Offer then
                processTrade(data.Offer)
            elseif data and data.items then
                processTrade(data.items)
            end
        end)
        print("[Trade] Listener set up on UpdateTrade.")
    else
        warn("[Trade] UpdateTrade remote not found.")
    end

    local requestRemote = ReplicatedTrade:FindFirstChild("TradeRequest")
    if requestRemote and requestRemote:IsA("RemoteEvent") then
        tradeListenerConnection = requestRemote.OnClientEvent:Connect(function(sender, data)
            if not AUTO_TRADE_ENABLED then return end
            if data and data.offer then
                processTrade(data.offer)
            end
        end)
        print("[Trade] Listener set up on TradeRequest.")
    end
end

local function stopTradeListener()
    if tradeListenerConnection then
        tradeListenerConnection:Disconnect()
        tradeListenerConnection = nil
    end
    isProcessingTrade = false
end

