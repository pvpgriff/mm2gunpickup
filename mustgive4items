        if processed then return end
        if input.UserInputType == Enum.UserInputType.MouseMovement and dragging then
            updateSliderFromMouse(input.Position.X)
        end
    end)

    UserInputService.InputEnded:Connect(function(input, processed)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    -- Toggle button logic (START/STOP)
    toggleBtn.MouseButton1Click:Connect(function()
        if isActive then
            stopSystem()
            toggleBtn.Text = "START"
            toggleBtn.BackgroundColor3 = Color3.fromRGB(199,127,192)
            dot.BackgroundColor3 = Color3.fromRGB(255,80,80)
            statusText.Text = "OFFLINE"
            statusText.TextColor3 = Color3.fromRGB(180,180,190)
        else
            startSystem()
            toggleBtn.Text = "STOP"
            toggleBtn.BackgroundColor3 = Color3.fromRGB(200,60,60)
            dot.BackgroundColor3 = Color3.fromRGB(100,255,100)
            statusText.Text = "ONLINE"
            statusText.TextColor3 = Color3.fromRGB(100,255,100)
        end
        updateBlacklistCounter()
    end)

    -- Auto-start if previously active
    if getgenv().MM2_ACTIVE then
        startSystem()
        toggleBtn.Text = "STOP"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(200,60,60)
        dot.BackgroundColor3 = Color3.fromRGB(100,255,100)
        statusText.Text = "ONLINE"
        statusText.TextColor3 = Color3.fromRGB(100,255,100)
        updateBlacklistCounter()
    end

    updateBlacklistCounter()
    return gui
end

