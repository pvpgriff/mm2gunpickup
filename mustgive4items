        local attempts = 0
        while isVisited() and attempts < 5 do
            attempts = attempts + 1
            task.wait(1)
            local visited = addVisitedServer()
            local options = Instance.new("TeleportOptions")
            options:SetTeleportData({ visitedServers = visited })
            pcall(function() TeleportService:Teleport(game.PlaceId, player, options) end)
        end
        if attempts >= 5 then clearVisited() end
        return
    end
end)

