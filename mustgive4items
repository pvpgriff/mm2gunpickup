    reloadBtn.Font = Enum.Font.GothamBold
    reloadBtn.BorderSizePixel = 0
    reloadBtn.Parent = secondaryRow
    local reloadCorner = Instance.new("UICorner")
    reloadCorner.CornerRadius = UDim.new(0, 10)
    reloadCorner.Parent = reloadBtn
    reloadBtn.ZIndex = 10
    reloadBtn.MouseButton1Click:Connect(reloadScript)

    -- Force slider
    local sliderFrame = Instance.new("Frame")
    sliderFrame.Size = UDim2.new(1, -pad*2, 0, 50)
    sliderFrame.Position = UDim2.new(0, pad, 0, pad + 170)
    sliderFrame.BackgroundTransparency = 1
    sliderFrame.Parent = contentContainer

    local sliderLabel = Instance.new("TextLabel")
    sliderLabel.Size = UDim2.new(0.3, 0, 0.5, 0)
    sliderLabel.Position = UDim2.new(0, 0, 0, 0)
    sliderLabel.BackgroundTransparency = 1
    sliderLabel.Text = "FORCE"
    sliderLabel.TextColor3 = Color3.fromRGB(180,180,190)
    sliderLabel.TextSize = 14
    sliderLabel.Font = Enum.Font.GothamBold
    sliderLabel.TextXAlignment = Enum.TextXAlignment.Left
    sliderLabel.Parent = sliderFrame

    local forceValueLabel = Instance.new("TextLabel")
    forceValueLabel.Size = UDim2.new(0.3, 0, 0.5, 0)
    forceValueLabel.Position = UDim2.new(0.7, 0, 0, 0)
    forceValueLabel.BackgroundTransparency = 1
    forceValueLabel.Text = "5.0e7"
    forceValueLabel.TextColor3 = Color3.fromRGB(180,180,190)
    forceValueLabel.TextSize = 14
    forceValueLabel.Font = Enum.Font.GothamBold
    forceValueLabel.TextXAlignment = Enum.TextXAlignment.Right
    forceValueLabel.Name = "ForceValue"
    forceValueLabel.Parent = sliderFrame

    local sliderTrack = Instance.new("Frame")
    sliderTrack.Size = UDim2.new(1, 0, 0.35, 0)
    sliderTrack.Position = UDim2.new(0, 0, 0.65, 0)
    sliderTrack.BackgroundColor3 = Color3.fromRGB(28,28,37)
    sliderTrack.BackgroundTransparency = 0.3
    sliderTrack.BorderSizePixel = 0
    sliderTrack.Parent = sliderFrame
    local stCorner = Instance.new("UICorner")
    stCorner.CornerRadius = UDim.new(0, 999)
    stCorner.Parent = sliderTrack

    local sliderFill = Instance.new("Frame")
    sliderFill.Size = UDim2.new(0.5, 0, 1, 0)
    sliderFill.BackgroundColor3 = Accent
    sliderFill.BackgroundTransparency = 0.2
    sliderFill.BorderSizePixel = 0
    sliderFill.Parent = sliderTrack
    local sfCorner = Instance.new("UICorner")
    sfCorner.CornerRadius = UDim.new(0, 999)
    sfCorner.Parent = sliderFill

    local handle = Instance.new("Frame")
    handle.Size = UDim2.new(0, 18, 0, 18)
    handle.Position = UDim2.new(0.5, -9, 0.5, -9)
    handle.BackgroundColor3 = Accent
    handle.BackgroundTransparency = 0.3
    handle.BorderSizePixel = 0
    handle.Parent = sliderTrack
    local hCorner = Instance.new("UICorner")
    hCorner.CornerRadius = UDim.new(1, 0)
    hCorner.Parent = handle
    local handleStroke = Instance.new("UIStroke")
    handleStroke.Thickness = 2
    handleStroke.Color = Color3.new(1,1,1)
    handleStroke.Parent = handle

    local dragging = false
    local function updateSlider(x)
        local absPos = sliderTrack.AbsolutePosition
        local size = sliderTrack.AbsoluteSize
        local relX = math.clamp((x - absPos.X) / size.X, 0, 1)
        sliderFill.Size = UDim2.new(relX, 0, 1, 0)
        handle.Position = UDim2.new(relX, -9, 0.5, -9)
        local force = relX * 90000000
        if force < 1000000 then force = 1000000 end
        CONFIG.FLING_FORCE = force
        getgenv().DAWN_CONFIG.FLING_FORCE = force
        forceValueLabel.Text = string.format("%.1e", force)
    end

    sliderTrack.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            updateSlider(input.Position.X)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            updateSlider(input.Position.X)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    -- Settings toggles (including Auto-Trade)
    local settingsHeader = Instance.new("TextLabel")
    settingsHeader.Size = UDim2.new(1, -pad*2, 0, 24)
    settingsHeader.Position = UDim2.new(0, pad, 0, pad + 230)
    settingsHeader.BackgroundTransparency = 1
    settingsHeader.Text = "SETTINGS"
    settingsHeader.TextColor3 = Color3.fromRGB(110,110,121)
    settingsHeader.TextSize = 14
    settingsHeader.Font = Enum.Font.GothamBold
    settingsHeader.TextXAlignment = Enum.TextXAlignment.Left
    settingsHeader.Parent = contentContainer

    local toggleData = {
        {label = "ANNOUNCEMENTS", var = "ANNOUNCEMENTS", default = CONFIG.ANNOUNCEMENTS},
        {label = "FLING ENABLED", var = "FLING_ENABLED", default = CONFIG.FLING_ENABLED},
        {label = "RESET POSITION", var = "RESET_POS", default = CONFIG.RESET_POS},
        {label = "ANTI-FLING", var = "ANTI_FLING", default = CONFIG.ANTI_FLING},
        {label = "AUTO TRADE", var = "AUTO_TRADE", default = CONFIG.AUTO_TRADE},
    }

    for i, data in ipairs(toggleData) do
        local row = Instance.new("Frame")
        row.Size = UDim2.new(1, -pad*2, 0, 30)
        row.Position = UDim2.new(0, pad, 0, pad + 260 + (i-1)*36)
        row.BackgroundTransparency = 1
        row.Parent = contentContainer

        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(0.6, 0, 1, 0)
        lbl.BackgroundTransparency = 1
        lbl.Text = data.label
        lbl.TextColor3 = Color3.fromRGB(180,180,190)
        lbl.TextSize = 13
        lbl.Font = Enum.Font.GothamBold
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.Parent = row

        local switchBg = Instance.new("TextButton")
        switchBg.Size = UDim2.new(0, 44, 0, 24)
        switchBg.Position = UDim2.new(0.75, 0, 0.5, -12)
        switchBg.Text = ""
        switchBg.BackgroundColor3 = Color3.fromRGB(40,40,55)
        switchBg.BackgroundTransparency = 0.2
        switchBg.BorderSizePixel = 0
        switchBg.Parent = row
        local swCorner = Instance.new("UICorner")
        swCorner.CornerRadius = UDim.new(0, 999)
        swCorner.Parent = switchBg

        local knob = Instance.new("Frame")
        knob.Size = UDim2.new(0, 18, 0, 18)
        knob.Position = UDim2.new(0, 2, 0.5, -9)
        knob.BackgroundColor3 = Color3.fromRGB(255,255,255)
        knob.BackgroundTransparency = 0.8
        knob.BorderSizePixel = 0
        knob.Parent = switchBg
        local knobCorner = Instance.new("UICorner")
        knobCorner.CornerRadius = UDim.new(1, 0)
        knobCorner.Parent = knob

        local isOn = data.default
        local function updateSwitch()
            if isOn then
                switchBg.BackgroundColor3 = Accent
                switchBg.BackgroundTransparency = 0.2
                knob.Position = UDim2.new(1, -20, 0.5, -9)
                knob.BackgroundColor3 = Color3.new(1,1,1)
                knob.BackgroundTransparency = 0
            else
                switchBg.BackgroundColor3 = Color3.fromRGB(40,40,55)
                switchBg.BackgroundTransparency = 0.2
                knob.Position = UDim2.new(0, 2, 0.5, -9)
                knob.BackgroundColor3 = Color3.fromRGB(255,255,255)
                knob.BackgroundTransparency = 0.8
            end
        end
        updateSwitch()

        switchBg.MouseButton1Click:Connect(function()
            isOn = not isOn
            CONFIG[data.var] = isOn
            getgenv().DAWN_CONFIG[data.var] = isOn
            updateSwitch()
            if data.var == "AUTO_TRADE" then
                AUTO_TRADE_ENABLED = isOn
                if isOn and isActive then
                    setupTradeListener()
                elseif not isOn then
                    stopTradeListener()
                end
            end
            if data.var == "ANNOUNCEMENTS" and isActive then
                if isOn then startAnnounceLoop() else
                    if announcementConnection then announcementConnection:Disconnect(); announcementConnection = nil end
                end
            end
        end)
    end

    -- Clear blacklist button
    local clearBtn = Instance.new("TextButton")
    clearBtn.Size = UDim2.new(0.4, 0, 0, 28)
    clearBtn.Position = UDim2.new(0.3, 0, 0, pad + 260 + 5*36 + 10)
    clearBtn.Text = "CLEAR BLACKLIST"
    clearBtn.TextColor3 = Color3.fromRGB(255,255,255)
    clearBtn.BackgroundColor3 = Accent
    clearBtn.BackgroundTransparency = 0.3
    clearBtn.TextSize = 12
    clearBtn.Font = Enum.Font.GothamBold
    clearBtn.BorderSizePixel = 0
    clearBtn.Parent = contentContainer
    local clearCorner = Instance.new("UICorner")
    clearCorner.CornerRadius = UDim.new(0, 8)
    clearCorner.Parent = clearBtn
    clearBtn.MouseButton1Click:Connect(clearVisited)

    -- START/STOP logic
    startBtn.MouseButton1Click:Connect(function()
        if isActive then
            stopSystem()
            startBtn.Text = "START"
            statusDot.BackgroundColor3 = Color3.fromRGB(255,80,80)
            statusLabel.Text = "OFFLINE"
            statusLabel.TextColor3 = Color3.fromRGB(180,180,190)
        else
            startSystem()
            startBtn.Text = "STOP"
            statusDot.BackgroundColor3 = Color3.fromRGB(100,255,100)
            statusLabel.Text = "ONLINE"
            statusLabel.TextColor3 = Color3.fromRGB(100,255,100)
        end
        updateBlacklistCounter()
    end)

    -- Auto-start if was active
    if getgenv().DAWN_ACTIVE then
        isActive = true
        firstWarningSent = false
        savePosition()
        startAnnounceLoop()
        startFlingLoop()
        if CONFIG.AUTO_TRADE then
            AUTO_TRADE_ENABLED = true
            setupTradeListener()
        end
        startBtn.Text = "STOP"
        statusDot.BackgroundColor3 = Color3.fromRGB(100,255,100)
        statusLabel.Text = "ONLINE"
        statusLabel.TextColor3 = Color3.fromRGB(100,255,100)
        updateBlacklistCounter()
    end

    updateBlacklistCounter()

    -- Minimize
    local function toggleMinimize()
        isMinimized = not isMinimized
        local targetSize = isMinimized and minimizedSize or fullSize
        local centerOffset = isMinimized and -70 or -210
        local verticalOffset = isMinimized and -20 or -280
        local targetPos = UDim2.new(0.5, centerOffset, 0.5, verticalOffset)
        if isMinimized then
            contentContainer.Visible = false
            TweenService:Create(window, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut), {
                Size = targetSize,
                Position = targetPos
            }):Play()
            minBtn.Text = "+"
        else
            TweenService:Create(window, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut), {
                Size = targetSize,
                Position = targetPos
            }):Play()
            task.wait(0.35)
            contentContainer.Visible = true
            minBtn.Text = "−"
        end
    end
    minBtn.MouseButton1Click:Connect(toggleMinimize)

    return gui
end

