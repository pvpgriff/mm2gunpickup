    FLING_INTERVAL_MIN = 25,    -- seconds between fling cycles
    FLING_INTERVAL_MAX = 35,
    FLING_WARNING_DELAY = 5,
    NO_TRADE_TIMEOUT = 45,
    GLOBAL_CHAT_COOLDOWN = 5,   -- minimum seconds between any chat send
    DEBUG = true,
}

-- ============================================
-- STATE
-- ============================================
